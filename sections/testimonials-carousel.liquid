{% comment %}
  Testimonials Carousel Section with Animated Shapes for Shopify Dawn Theme.
  Social proof section with Instagram-style cards, scroll-snap, and dynamic background.
{% endcomment %}

<style>
  .testimonials-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    overflow: hidden;
    position: relative; /* Importante para el posicionamiento de las formas */
  }

  .testimonials-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative; /* Asegura que el contenido esté sobre las formas */
    z-index: 10; 
  }

  /* --- FORMAS ANIMADAS DEL FONDO --- */
  .animated-shapes {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 1; /* Detrás del contenido */
  }

  .shape {
    position: absolute;
    filter: blur(5px);
    border-radius: 50%;
    animation: floatShape 20s ease-in-out infinite;
    transition: opacity 0.5s ease;
  }

  /* Definición de formas específicas */
  .shape-1 {
    width: 15vw;
    height: 15vw;
    background: linear-gradient(135deg, {{ section.settings.primary_color }} 0%, #ffffff00 100%);
    opacity: 0.15;
    top: -5%;
    left: -10%;
    animation-duration: 25s;
    animation-delay: -5s;
  }

  .shape-2 {
    width: 10vw;
    height: 10vw;
    border: 3px solid {{ section.settings.primary_color }};
    opacity: 0.08;
    bottom: 20%;
    left: 5%;
    border-radius: 2vw; /* Cuadrado redondeado */
    animation-duration: 18s;
  }

  .shape-3 {
    width: 12vw;
    height: 12vw;
    background: linear-gradient(135deg, {{ section.settings.secondary_color }} 0%, #ffffff00 100%);
    opacity: 0.12;
    top: 40%;
    left: 80%;
    animation-duration: 22s;
    animation-delay: -10s;
  }

  .shape-4 {
    width: 8vw;
    height: 8vw;
    border: 2px solid {{ section.settings.secondary_color }};
    opacity: 0.1;
    top: -8%;
    left: 65%;
    animation-duration: 15s;
    animation-delay: -2s;
  }

  .shape-5 {
    width: 6vw;
    height: 6vw;
    background-color: {{ section.settings.primary_color }};
    opacity: 0.05;
    bottom: -5%;
    left: 95%;
    animation-duration: 12s;
  }

  /* Animación de flotación */
  @keyframes floatShape {
    0%, 100% {
      transform: translate(0, 0) rotate(0deg);
    }
    25% {
      transform: translate(5%, 15%) rotate(15deg);
    }
    50% {
      transform: translate(15%, 5%) rotate(-10deg);
    }
    75% {
      transform: translate(5%, -10%) rotate(5deg);
    }
  }

  /* Ocultar formas en móvil para mejorar el rendimiento si se desea */
  /* @media (max-width: 749px) { .animated-shapes { display: none; } } */

  /* --- RESTO DE ESTILOS EXISTENTES --- */
  .testimonials-header {
    text-align: center;
    margin-bottom: 50px;
  }

  .testimonials-title {
    font-size: 36px;
    font-weight: 800;
    color: {{ section.settings.text_color }};
    margin-bottom: 10px;
    letter-spacing: -0.02em;
    line-height: 1.3;
  }

  @media (min-width: 750px) {
    .testimonials-title { font-size: 48px; }
  }

  /* SUBRAYADO ANIMADO AL HACER SCROLL */
  .testimonials-accent {
    position: relative;
    display: inline-block;
    z-index: 1;
    padding: 0 5px;
  }

  .accent-text {
    background: linear-gradient(to right, {{ section.settings.primary_color }}, {{ section.settings.secondary_color }});
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    position: relative;
    z-index: 2;
  }

  .testimonials-accent::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 12%; 
    width: 0; 
    height: 38%; 
    background-color: {{ section.settings.secondary_color }};
    opacity: 0.3; 
    z-index: 1;
    border-radius: 2px;
    transition: width 1s cubic-bezier(0.65, 0, 0.35, 1);
  }

  .testimonials-accent.is-visible::after {
    width: 100%;
  }

  .testimonials-subtitle {
    font-size: 18px;
    color: #64748b;
  }

  /* Slider Logic */
  .testimonials-slider {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    gap: 24px;
    padding: 20px 0 40px 0;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .testimonials-slider::-webkit-scrollbar {
    display: none;
  }

  .testimonial-card {
    flex: 0 0 85%;
    scroll-snap-align: center;
    background: rgba(255, 255, 255, 0.9); /* Fondo semi-transparente */
    backdrop-filter: blur(10px); /* Desenfoque de fondo para destacar */
    -webkit-backdrop-filter: blur(10px);
    border-radius: 24px;
    padding: 32px;
    border: 1px solid rgba(226, 232, 240, 0.8);
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
    position: relative;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  /* Efecto sutil al pasar el ratón */
  .testimonial-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 35px -10px rgba(0,0,0,0.1);
  }

  @media (min-width: 750px) {
    .testimonial-card { flex: 0 0 calc(50% - 12px); scroll-snap-align: start; }
  }

  @media (min-width: 990px) {
    .testimonial-card { flex: 0 0 calc(33.333% - 16px); }
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    position: relative;
  }

  .ig-icon {
    position: absolute;
    top: 0;
    right: 0;
    color: #cbd5e1;
    transform: translate(5px, -5px); /* Ajuste sutil */
  }

  .client-logo {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #f1f5f9;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    color: {{ section.settings.primary_color }};
    overflow: hidden;
    border: 1px solid #e2e8f0;
  }

  .client-logo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .client-meta h4 {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    color: #0f172a;
  }

  .stars {
    display: flex;
    gap: 2px;
    margin: 4px 0;
  }

  .star-icon {
    width: 14px;
    height: 14px;
    fill: #fbbf24;
    color: #fbbf24;
  }

  .client-handle {
    font-size: 12px;
    color: #94a3b8;
    font-weight: 500;
  }

  .testimonial-text {
    font-size: 14px;
    line-height: 1.6;
    color: #475569;
    font-style: italic;
    margin: 0;
  }

  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 10px;
    min-height: 24px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #cbd5e1;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
    padding: 0;
  }

  .dot.active {
    width: 24px;
    border-radius: 10px;
    background: {{ section.settings.secondary_color }};
  }
</style>

<div class="testimonials-{{ section.id }}">
  <div class="animated-shapes">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
    <div class="shape shape-4"></div>
    <div class="shape shape-5"></div>
  </div>

  <div class="testimonials-container">
    <div class="testimonials-header">
      <h2 class="testimonials-title">
        {{ section.settings.title_start }} 
        <span class="testimonials-accent" id="Trigger-{{ section.id }}">
          <span class="accent-text">{{ section.settings.title_accent }}</span>
        </span>
      </h2>
      <p class="testimonials-subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="testimonials-slider" id="Slider-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="ig-icon">
            <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
          
          <div class="card-header">
            <div class="client-logo">
              {% if block.settings.image != blank %}
                <img src="{{ block.settings.image | img_url: '100x' }}" alt="{{ block.settings.name }}" loading="lazy">
              {% else %}
                <span>{{ block.settings.name | slice: 0, 2 | upcase }}</span>
              {% endif %}
            </div>
            <div class="client-meta">
              <h4>{{ block.settings.name }}</h4>
              <div class="stars">
                {% for i in (1..block.settings.rating) %}
                  <svg class="star-icon" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                {% endfor %}
              </div>
              <p class="client-handle">{{ block.settings.handle }}</p>
            </div>
          </div>

          <p class="testimonial-text">"{{ block.settings.text }}"</p>
        </div>
      {% endfor %}
    </div>

    <div class="slider-dots" id="Dots-{{ section.id }}"></div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = '{{ section.id }}';
    const slider = document.getElementById('Slider-' + sectionId);
    const dotsContainer = document.getElementById('Dots-' + sectionId);
    const trigger = document.getElementById('Trigger-' + sectionId);
    
    if (!slider || !dotsContainer) return;

    // --- LÓGICA DE INTERSECTION OBSERVER PARA EL SUBRAYADO ---
    const observerOptions = {
      root: null,
      threshold: 0.8
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    if (trigger) observer.observe(trigger);


    // --- LÓGICA DEL CARRUSEL ---
    let dots = [];

    const initDots = () => {
      const card = slider.querySelector('.testimonial-card');
      if (!card) return;

      const cardWidth = card.offsetWidth + 24; 
      const maxScroll = slider.scrollWidth - slider.clientWidth;
      
      if (cardWidth <= 0 || slider.clientWidth <= 0) return;

      let totalDots = Math.round(maxScroll / cardWidth) + 1;
      if (totalDots < 1) totalDots = 1;

      dotsContainer.innerHTML = '';
      dots = [];

      if (maxScroll <= 0) return;

      for (let i = 0; i < totalDots; i++) {
        const dot = document.createElement('button');
        dot.className = `dot ${i === 0 ? 'active' : ''}`;
        dot.setAttribute('data-index', i);
        
        dot.addEventListener('click', () => {
          slider.scrollTo({
            left: cardWidth * i,
            behavior: 'smooth'
          });
        });

        dotsContainer.appendChild(dot);
        dots.push(dot);
      }
      
      updateActiveDot();
    };

    const updateActiveDot = () => {
      if (dots.length === 0) return;
      
      const card = slider.querySelector('.testimonial-card');
      if (!card) return;
      
      const cardWidth = card.offsetWidth + 24;
      const maxScroll = slider.scrollWidth - slider.clientWidth;
      
      let index = 0;
      
      if (Math.abs(slider.scrollLeft - maxScroll) < 10) {
         index = dots.length - 1;
      } else {
         index = Math.round(slider.scrollLeft / cardWidth);
      }
      
      index = Math.min(index, dots.length - 1);

      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === index);
      });
    };

    setTimeout(initDots, 100);
    
    slider.addEventListener('scroll', () => {
      window.requestAnimationFrame(updateActiveDot);
    });

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(initDots, 250);
    });
  });
</script>

{% schema %}
{
  "name": "Testimonios Carrusel",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "title_start",
      "label": "Inicio del Título",
      "default": "Negocios que"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Palabra Acento",
      "default": "confiaron"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Algunos comentarios:"
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Color Primario (Indigo)",
      "default": "#4f46e5"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Color Secundario (Emerald)",
      "default": "#10b981"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de Sección",
      "default": "#f1f5f9"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de Texto",
      "default": "#0f172a"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonio",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto/Logo del Cliente"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre",
          "default": "Nombre del Cliente"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Usuario (@cuenta)",
          "default": "@cliente.ig"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Estrellas",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Comentario",
          "default": "Excelente servicio, la web ha superado mis expectativas."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonios Carrusel",
      "blocks": [
        { "type": "testimonial", "settings": { "name": "Óptica Visur", "handle": "@optica.visur" } },
        { "type": "testimonial", "settings": { "name": "Elite Solutions", "handle": "@elitesolutions.cl" } },
        { "type": "testimonial", "settings": { "name": "Madratek", "handle": "@Madratekstore" } }
      ]
    }
  ]
}
{% endschema %}