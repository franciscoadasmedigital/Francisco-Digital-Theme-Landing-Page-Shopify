{% comment %}
  Sección "Trayectoria Editorial" para Shopify Dawn.
  Diseño asimétrico con estadísticas flotantes y texto de fondo gigante.
  Título con palabra destacable editable.
{% endcomment %}

<style>
  .about-ed-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    color: #ffffff;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    position: relative;
    overflow: hidden;
  }

  /* Texto Gigante de Fondo */
  .ed-bg-text-{{ section.id }} {
    position: absolute;
    top: 15%;
    right: -5%;
    font-size: 20vw;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.03);
    line-height: 1;
    pointer-events: none;
    z-index: 1;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .ed-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
    position: relative;
    z-index: 2;
  }

  .ed-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px;
    align-items: center;
  }

  @media (min-width: 990px) {
    .ed-grid { grid-template-columns: 1.2fr 0.8fr; }
  }

  /* Lado de la Narrativa */
  .ed-badge {
    display: inline-block;
    padding: 4px 16px;
    border-radius: 100px;
    border: 1px solid {{ section.settings.accent_color }}44;
    background: {{ section.settings.accent_color }}11;
    color: {{ section.settings.accent_color }};
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
  }

  .ed-title {
    font-size: 36px;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 32px;
    color: #ffffff;
  }

  @media (min-width: 750px) { .ed-title { font-size: 60px; } }

  .ed-title span {
    color: {{ section.settings.accent_color }};
    font-style: italic;
    font-family: inherit;
  }

  .ed-desc {
    font-size: 18px;
    line-height: 1.6;
    color: #94a3b8;
    border-left: 3px solid {{ section.settings.secondary_color }}44;
    padding-left: 24px;
    max-width: 600px;
  }

  /* Lado de Estadísticas - Ajustado para coincidir con la imagen */
  .ed-stats-grid {
    display: grid;
    grid-template-columns: 1fr; /* Mantenemos 1 columna para que se apilen como en la imagen */
    gap: 20px;
  }

  .ed-stat-card {
    background: #111827; /* Fondo azul muy oscuro casi negro */
    border: 1px solid #1e293b; /* Borde sutil */
    padding: 32px 40px;
    border-radius: 16px; /* Bordes redondeados más sutiles */
    display: flex;
    flex-direction: column;
    align-items: flex-start; /* Alineación a la izquierda */
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .ed-stat-card:hover {
    border-color: #334155;
    background: #151d30;
    transform: translateY(-5px); /* Efecto hover elegante en lugar de flotación constante */
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .ed-stat-number {
    display: block;
    font-size: 56px; /* Número más grande */
    font-weight: 900;
    margin-bottom: 12px;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .ed-stat-label {
    font-size: 13px;
    font-weight: 700;
    color: #64748b; /* Gris azulado sutil */
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 749px) {
    .ed-stat-card { padding: 24px 30px; }
    .ed-stat-number { font-size: 48px; }
  }
</style>

<div class="about-ed-{{ section.id }}">
  <div class="ed-bg-text-{{ section.id }}">{{ section.settings.bg_text }}</div>

  <div class="ed-container">
    <div class="ed-grid">
      
      <div class="ed-text-side">
        {% if section.settings.badge != blank %}
          <span class="ed-badge">{{ section.settings.badge }}</span>
        {% endif %}
        
        <h2 class="ed-title">
          {{ section.settings.title_1 }}
          <span>{{ section.settings.title_highlight }}</span>
          {{ section.settings.title_2 }}
        </h2>

        <div class="ed-desc">
          {{ section.settings.description }}
        </div>
      </div>

      <div class="ed-stats-side">
        <div class="ed-stats-grid">
          {% for block in section.blocks %}
            <div class="ed-stat-card" {{ block.shopify_attributes }}>
              <span class="ed-stat-number" style="color: {{ block.settings.color }};">{{ block.settings.number }}</span>
              <span class="ed-stat-label">{{ block.settings.label }}</span>
            </div>
          {% endfor %}
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Trayectoria Editorial",
  "settings": [
    {
      "type": "header",
      "content": "Contenido del Título"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Inicio del Título",
      "default": "Impulsando la evolución"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "Palabra a destacar",
      "default": "digital"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Final del Título",
      "default": "de tu negocio."
    },
    {
      "type": "header",
      "content": "Textos Secundarios"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Etiqueta superior",
      "default": "Trayectoria & Visión"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descripción Narrativa",
      "default": "<p>Hola, soy Pablete Digital 👋. Hace 7 años descubrí que una web no debe ser solo un folleto digital, sino un activo financiero que trabaje 24/7 para ti.</p>"
    },
    {
      "type": "text",
      "id": "bg_text",
      "label": "Texto Gigante de Fondo",
      "default": "EXPERTO"
    },
    {
      "type": "header",
      "content": "Estilos y Colores"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de Sección",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Color de Acento (Destacados)",
      "default": "#6366f1"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Color Secundario (Borde)",
      "default": "#10b981"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 120
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Estadística",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Número",
          "default": "+100"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Descripción",
          "default": "Clientes con éxito"
        },
        {
          "type": "color",
          "id": "color",
          "label": "Color del Número",
          "default": "#6366f1"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trayectoria Editorial",
      "blocks": [
        { "type": "stat", "settings": { "number": "+100", "label": "Clientes con éxito digital", "color": "#6366f1" } },
        { "type": "stat", "settings": { "number": "+5", "label": "Ecosistemas Web Creados", "color": "#10b981" } },
        { "type": "stat", "settings": { "number": "+1", "label": "Año de Estrategia Pura", "color": "#6366f1" } }
      ]
    }
  ]
}
{% endschema %}