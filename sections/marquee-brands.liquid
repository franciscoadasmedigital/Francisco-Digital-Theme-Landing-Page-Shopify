{% comment %}
  Custom Marquee Section for Shopify Dawn Theme.
  Allows infinite scrolling of brand logos with hover effects.
  Individual logo size control enabled.
{% endcomment %}

<style>
  .marquee-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    overflow: hidden;
    border-top: 1px solid {{ section.settings.border_color }};
    border-bottom: 1px solid {{ section.settings.border_color }};
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  .marquee-title-{{ section.id }} {
    color: {{ section.settings.text_color }};
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 40px;
    opacity: 0.8;
    text-align: center;
  }

  .marquee-wrapper-{{ section.id }} {
    display: flex;
    width: 100%;
    position: relative;
    mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 10%, black 90%, transparent);
    overflow: hidden;
  }

  .marquee-content-{{ section.id }} {
    display: flex;
    flex-wrap: nowrap;
    gap: 60px;
    animation: marquee-scroll {{ section.settings.speed }}s linear infinite;
    padding-left: 60px;
  }

  .marquee-wrapper-{{ section.id }}:hover .marquee-content-{{ section.id }} {
    animation-play-state: paused;
  }

  .brand-item-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    flex-shrink: 0;
    transition: all 0.3s ease;
    filter: grayscale(100%);
    opacity: 0.6;
  }

  .brand-item-{{ section.id }}:hover {
    filter: grayscale(0%);
    opacity: 1;
    transform: scale(1.05);
  }

  .brand-logo-{{ section.id }} {
    height: auto; 
    /* Usamos la variable CSS definida en el HTML, con 80px como respaldo */
    max-height: var(--logo-height, 80px); 
    width: auto;
    max-width: 100%; 
    object-fit: contain;
  }

  .brand-name-{{ section.id }} {
    color: {{ section.settings.brand_text_color }};
    font-size: 24px;
    font-weight: 800;
    white-space: nowrap;
    letter-spacing: -0.02em;
  }

  @keyframes marquee-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 749px) {
    .brand-name-{{ section.id }} { font-size: 20px; }
    .marquee-content-{{ section.id }} { gap: 40px; }
    /* Escala el tamaño individual un 30% más pequeño en móviles */
    .brand-logo-{{ section.id }} { 
      max-height: calc(var(--logo-height, 80px) * 0.7); 
    }
  }
</style>

<div class="marquee-section-{{ section.id }}">
  {% if section.settings.title != blank %}
    <p class="marquee-title-{{ section.id }}">{{ section.settings.title }}</p>
  {% endif %}

  <div class="marquee-wrapper-{{ section.id }}">
    <div class="marquee-content-{{ section.id }}">
      {% for i in (1..4) %}
        {% for block in section.blocks %}
          {% comment %} Inyectamos la altura elegida como una variable CSS inline {% endcomment %}
          <div class="brand-item-{{ section.id }}" {{ block.shopify_attributes }} style="--logo-height: {{ block.settings.logo_height }}px;">
            {% if block.settings.logo != blank %}
              <img 
                src="{{ block.settings.logo | image_url: width: 400 }}" 
                alt="{{ block.settings.name | escape }}"
                width="{{ block.settings.logo.width }}"
                height="{{ block.settings.logo.height }}"
                class="brand-logo-{{ section.id }}"
                loading="lazy"
              >
            {% endif %}
            {% if block.settings.name != blank %}
              <span class="brand-name-{{ section.id }}">{{ block.settings.name }}</span>
            {% endif %}
          </div>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Marquesina de Marcas",
  "settings": [
    {
      "type": "header",
      "content": "Contenido"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título de la sección",
      "default": "Marcas que confían en nosotros"
    },
    {
      "type": "header",
      "content": "Configuración Visual General"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de fondo",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del título",
      "default": "#94a3b8"
    },
    {
      "type": "color",
      "id": "brand_text_color",
      "label": "Color nombre de marcas",
      "default": "#1e293b"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color de bordes",
      "default": "#e2e8f0"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "label": "Velocidad (segundos por vuelta)",
      "default": 40
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Marca",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Logo de la marca"
        },
        {
          "type": "range",
          "id": "logo_height",
          "min": 20,
          "max": 200,
          "step": 5,
          "unit": "px",
          "label": "Altura de este logo",
          "default": 80
        },
        {
          "type": "text",
          "id": "name",
          "label": "Nombre de la marca",
          "default": "Marca"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquesina de Marcas",
      "blocks": [
        { "type": "brand", "settings": { "name": "TechNova", "logo_height": 80 } },
        { "type": "brand", "settings": { "name": "EcoLife", "logo_height": 80 } },
        { "type": "brand", "settings": { "name": "BeautyCo", "logo_height": 80 } },
        { "type": "brand", "settings": { "name": "UrbanWear", "logo_height": 80 } }
      ]
    }
  ]
}
{% endschema %}