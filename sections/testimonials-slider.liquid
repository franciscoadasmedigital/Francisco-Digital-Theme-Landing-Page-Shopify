{% schema %}
{
  "name": "Testimonials Slider Pro",
  "settings": [
    {
      "type": "color",
      "id": "section_bg",
      "label": "Background color",
      "default": "#0f001f"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Company Logo"
        },
        {
          "type": "text",
          "id": "company",
          "label": "Company name",
          "default": "Optica Visur"
        },
        {
          "type": "text",
          "id": "username",
          "label": "Instagram username",
          "default": "@optica.visur"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Testimonial text",
          "default": "Muy conforme con los servicios..."
        },
        {
          "type": "range",
          "id": "stars",
          "label": "Stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials Slider Pro"
    }
  ]
}
{% endschema %}

<section id="testimonial-section-{{ section.id }}" class="testimonial-section" style="background: {{ section.settings.section_bg }}">
  <div class="testimonial-wrapper">
    
    <div class="testimonial-slider">
      {% for block in section.blocks %}
      <div class="testimonial-card" {{ block.shopify_attributes }}>
        
        <div class="logo-area">
          {% if block.settings.logo != blank %}
            <img 
              src="{{ block.settings.logo | image_url: width: 80 }}" 
              alt="{{ block.settings.company }}"
              class="company-logo"
            >
          {% endif %}
          
          <div class="company-info">
            <h3>{{ block.settings.company }}</h3>
            
            <div class="stars">
              {% for i in (1..block.settings.stars) %}
                ★
              {% endfor %}
            </div>

            <span class="username">{{ block.settings.username }}</span>
          </div>
        </div>

        <p class="testimonial-text">
          {{ block.settings.text }}
        </p>

      </div>
      {% endfor %}
    </div>

    <div class="testimonial-dots"></div>

  </div>
</section>

<style>
.testimonial-section {
  padding: 70px 20px;
}

.testimonial-wrapper {
  max-width: 1200px;
  margin: 0 auto;
  overflow: hidden;
  position: relative;
}

.testimonial-slider {
  display: flex;
  transition: transform 0.6s ease;
}

.testimonial-card {
  background: #f4f4f4;
  border-radius: 16px;
  padding: 24px;
  box-sizing: border-box;
}

/* Desktop 3 columnas */
@media screen and (min-width: 990px) {
  .testimonial-card {
    width: 33.3333%;
  }
}

/* Mobile 1 columna */
@media screen and (max-width: 989px) {
  .testimonial-card {
    width: 100%;
  }
}

.logo-area {
  display: flex;
  align-items: center;
  gap: 14px;
}

.company-logo {
  width: 55px;
  height: 55px;
  border-radius: 50%;
  object-fit: cover;
}

.company-info h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 600;
}

.stars {
  color: #f5a623;
  font-size: 14px;
  margin: 4px 0;
}

.username {
  font-size: 14px;
  color: #666;
}

.testimonial-text {
  margin-top: 18px;
  font-size: 15px;
  line-height: 1.6;
  color: #333;
}

/* Dots */
.testimonial-dots {
  margin-top: 25px;
  text-align: center;
}

.testimonial-dots span {
  height: 9px;
  width: 9px;
  margin: 0 5px;
  background: #ccc;
  border-radius: 50%;
  display: inline-block;
  cursor: pointer;
  transition: background 0.3s;
}

.testimonial-dots span.active {
  background: #7EAC14;
}
</style>

<script>
(function() {

  function initTestimonialSlider(sectionId) {
    const section = document.getElementById("testimonial-section-" + sectionId);
    if (!section) return;

    const slider = section.querySelector(".testimonial-slider");
    const dotsContainer = section.querySelector(".testimonial-dots");
    const cards = section.querySelectorAll(".testimonial-card");

    if (!slider || cards.length === 0) return;

    let currentIndex = 0;
    let visibleCards = window.innerWidth >= 990 ? 3 : 1;
    let totalSlides = Math.ceil(cards.length / visibleCards);

    function updateSlider() {
      visibleCards = window.innerWidth >= 990 ? 3 : 1;
      totalSlides = Math.ceil(cards.length / visibleCards);

      const cardWidth = cards[0].offsetWidth;
      slider.style.transform = `translateX(-${currentIndex * cardWidth * visibleCards}px)`;

      dotsContainer.querySelectorAll("span").forEach(dot => dot.classList.remove("active"));
      if (dotsContainer.children[currentIndex]) {
        dotsContainer.children[currentIndex].classList.add("active");
      }
    }

    function createDots() {
      dotsContainer.innerHTML = "";
      for (let i = 0; i < totalSlides; i++) {
        const dot = document.createElement("span");
        if (i === 0) dot.classList.add("active");

        dot.addEventListener("click", function() {
          currentIndex = i;
          updateSlider();
        });

        dotsContainer.appendChild(dot);
      }
    }

    function nextSlide() {
      currentIndex++;
      if (currentIndex >= totalSlides) {
        currentIndex = 0;
      }
      updateSlider();
    }

    createDots();
    updateSlider();

    setInterval(nextSlide, 5000);

    window.addEventListener("resize", function() {
      currentIndex = 0;
      createDots();
      updateSlider();
    });
  }

  document.addEventListener("DOMContentLoaded", function() {
    initTestimonialSlider("{{ section.id }}");
  });

  document.addEventListener("shopify:section:load", function(event) {
    if (event.detail.sectionId === "{{ section.id }}") {
      initTestimonialSlider("{{ section.id }}");
    }
  });

})();
</script>
