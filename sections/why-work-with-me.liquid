{% comment %}
  Sección "Por qué trabajar conmigo" para Shopify Dawn.
  Diseño oscuro premium con línea de tiempo vertical y título con degradado.
{% endcomment %}

<style>
  .why-work-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.page_bg_color }};
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .ww-container-{{ section.id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 60px 40px;
    background-color: {{ section.settings.card_bg_color }};
    border: 1px solid {{ section.settings.border_color }};
    border-radius: 24px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  @media (max-width: 749px) {
    .ww-container-{{ section.id }} {
      padding: 40px 20px;
      border-radius: 16px;
    }
  }

  .ww-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px;
    align-items: center;
  }

  @media (min-width: 990px) {
    .ww-grid { grid-template-columns: 1fr 1.2fr; gap: 80px; }
  }

  /* --- Lado Izquierdo: Textos y CTA --- */
  .ww-title-wrapper {
    margin-bottom: 24px;
  }

  .ww-title {
    font-size: 48px;
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  @media (min-width: 750px) { .ww-title { font-size: 64px; } }
  @media (min-width: 1200px) { .ww-title { font-size: 76px; } }

  .ww-gradient-text {
    background: linear-gradient(to right, {{ section.settings.gradient_start }}, {{ section.settings.gradient_end }});
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: block;
  }

  .ww-desc {
    font-size: 18px;
    line-height: 1.6;
    color: {{ section.settings.desc_color }};
    margin-bottom: 40px;
    max-width: 450px;
  }

  .ww-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: {{ section.settings.gradient_end }};
    border-radius: 100px;
    font-weight: 700;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .ww-btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: {{ section.settings.gradient_end }};
    transform: translateY(-2px);
  }

  .ww-btn svg {
    transition: transform 0.3s ease;
  }

  .ww-btn:hover svg {
    transform: translateX(4px);
  }

  /* --- Lado Derecho: Timeline --- */
  .ww-timeline {
    position: relative;
  }

  .ww-timeline-line {
    position: absolute;
    left: 23px; /* Centrado debajo del círculo de 48px */
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, {{ section.settings.gradient_start }}, {{ section.settings.timeline_color }}, transparent);
    z-index: 1;
  }

  @media (max-width: 749px) { .ww-timeline-line { display: none; } }

  .ww-step {
    position: relative;
    padding-left: 80px;
    margin-bottom: 48px;
  }

  .ww-step:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 749px) { 
    .ww-step { padding-left: 0; margin-bottom: 40px; } 
  }

  .ww-step-number {
    position: absolute;
    left: 0;
    top: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: {{ section.settings.card_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 800;
    z-index: 2;
  }

  @media (max-width: 749px) { .ww-step-number { display: none; } }

  .ww-step-content-wrapper {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  .ww-step-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ww-step-text h4 {
    font-size: 18px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: {{ section.settings.text_color }};
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .ww-step-text p {
    font-size: 14px;
    line-height: 1.6;
    color: {{ section.settings.desc_color }};
    margin: 0;
  }
</style>

<div class="why-work-{{ section.id }}">
  <div class="ww-container-{{ section.id }}">
    <div class="ww-grid">
      
      <!-- Columna Izquierda -->
      <div class="ww-left-side">
        <div class="ww-title-wrapper">
          <h2 class="ww-title">
            {{ section.settings.title_1 }}<br/>
            <span class="ww-gradient-text">{{ section.settings.title_2 }}</span>
            {{ section.settings.title_3 }}
          </h2>
        </div>
        
        <div class="ww-desc">
          {{ section.settings.description }}
        </div>

        {% if section.settings.btn_text != blank %}
          <a href="{{ section.settings.btn_link }}" class="ww-btn">
            {{ section.settings.btn_text }}
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {% endif %}
      </div>

      <!-- Columna Derecha -->
      <div class="ww-right-side">
        <div class="ww-timeline">
          <div class="ww-timeline-line"></div>
          
          {% for block in section.blocks %}
            <div class="ww-step" {{ block.shopify_attributes }}>
              <!-- Número circular con color dinámico -->
              <div class="ww-step-number" style="border: 2px solid {{ block.settings.step_color }}; color: {{ block.settings.step_color }};">
                {{ forloop.index }}
              </div>
              
              <div class="ww-step-content-wrapper">
                <!-- Ícono con color dinámico -->
                <div class="ww-step-icon" style="color: {{ block.settings.step_color }};">
                  {% if block.settings.custom_svg != blank %}
                    {{ block.settings.custom_svg }}
                  {% else %}
                    <!-- Íconos por defecto basados en selección -->
                    {% if block.settings.icon_type == 'compass' %}
                      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="m16.24 7.76-2.12 6.36-6.36 2.12 2.12-6.36 6.36-2.12z"/></svg>
                    {% elsif block.settings.icon_type == 'settings' %}
                      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 15a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                    {% else %}
                      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    {% endif %}
                  {% endif %}
                </div>
                
                <div class="ww-step-text">
                  <h4>{{ block.settings.title }}</h4>
                  <p>{{ block.settings.text }}</p>
                </div>
              </div>
            </div>
          {% endfor %}
          
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Por qué trabajar conmigo",
  "settings": [
    {
      "type": "header",
      "content": "Textos del Título"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Línea 1",
      "default": "POR QUÉ"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Línea 2 (Con Degradado)",
      "default": "TRABAJAR"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Línea 3",
      "default": "CONMIGO"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Tu socio estratégico para el éxito digital. Más que un proveedor, soy una extensión de tu equipo."
    },
    {
      "type": "header",
      "content": "Botón"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texto del Botón",
      "default": "INICIA TU PROYECTO"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Enlace del Botón"
    },
    {
      "type": "header",
      "content": "Colores Generales"
    },
    {
      "type": "color",
      "id": "page_bg_color",
      "label": "Fondo de la Página (Fuera de la tarjeta)",
      "default": "#1a1b26"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Fondo de la Tarjeta Principal",
      "default": "#1f2133"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Color del Borde de la Tarjeta",
      "default": "#312e81"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color Títulos Principales",
      "default": "#f8fafc"
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Color Textos Secundarios",
      "default": "#94a3b8"
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Degradado Inicial (Índigo)",
      "default": "#6366f1"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "Degradado Final (Lavanda)",
      "default": "#a5b4fc"
    },
    {
      "type": "color",
      "id": "timeline_color",
      "label": "Color Línea de Tiempo (Centro)",
      "default": "#10b981"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Paso / Pilar",
      "limit": 4,
      "settings": [
        {
          "type": "color",
          "id": "step_color",
          "label": "Color del Icono y Número",
          "default": "#6366f1"
        },
        {
          "type": "select",
          "id": "icon_type",
          "label": "Ícono predeterminado",
          "options": [
            { "value": "compass", "label": "Brújula" },
            { "value": "settings", "label": "Engranaje" },
            { "value": "users", "label": "Usuarios" }
          ],
          "default": "compass"
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "O usar Ícono SVG personalizado",
          "info": "Pega aquí el código HTML de tu SVG (<svg>...). Esto reemplazará el ícono predeterminado."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título del paso",
          "default": "DISEÑO A LA MEDIDA DE TU MARCA"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción",
          "default": "Soluciones personalizadas que capturan tu esencia y conectan con tu audiencia ideal."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Por qué trabajar conmigo",
      "category": "Custom Sections",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_color": "#6366f1",
            "icon_type": "compass",
            "title": "DISEÑO A LA MEDIDA DE TU MARCA",
            "text": "Soluciones personalizadas que capturan tu esencia y conectan con tu audiencia ideal, diferenciándote de la competencia."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_color": "#10b981",
            "icon_type": "settings",
            "title": "PROCESO DE DESARROLLO EFICIENTE",
            "text": "Metodología ágil y probada para entregar proyectos a tiempo, sin comprometer la calidad ni el rendimiento técnico."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_color": "#a5b4fc",
            "icon_type": "users",
            "title": "ACCESO A EXPERIENCIA MULTIDISCIPLINARIA",
            "text": "Especialistas en diseño, desarrollo y marketing trabajando en sinergia para lograr un resultado integral y rentable."
          }
        }
      ]
    }
  ]
}
{% endschema %}