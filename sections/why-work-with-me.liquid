{% comment %}
  Sección "Por qué trabajar conmigo" para Shopify Dawn.
  Diseño claro con línea de tiempo vertical y título con degradado.
{% endcomment %}

<style>
  .why-work-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    overflow: hidden;
  }

  .ww-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ww-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 60px;
    align-items: center;
  }

  @media (min-width: 990px) {
    .ww-grid { grid-template-columns: 1fr 1.2fr; gap: 80px; }
  }

  /* --- Lado Izquierdo: Textos y CTA --- */
  .ww-title-wrapper {
    margin-bottom: 24px;
  }

  .ww-title {
    font-size: 48px;
    font-weight: 900;
    line-height: 1.05;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    margin: 0;
    color: {{ section.settings.text_color }};
  }

  @media (min-width: 750px) { .ww-title { font-size: 72px; } }
  @media (min-width: 1200px) { .ww-title { font-size: 84px; } }

  .ww-gradient-text {
    background: linear-gradient(to right, {{ section.settings.gradient_start }}, {{ section.settings.gradient_end }});
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: block;
  }

  .ww-desc {
    font-size: 18px;
    line-height: 1.6;
    color: #4b5563;
    margin-bottom: 40px;
    max-width: 450px;
    font-weight: 500;
  }

  .ww-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px;
    background-color: {{ section.settings.btn_bg }};
    color: {{ section.settings.btn_text_color }};
    border-radius: 100px;
    font-weight: 800;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 10px 20px -5px {{ section.settings.btn_bg }}66;
  }

  .ww-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 15px 25px -5px {{ section.settings.btn_bg }}88;
    filter: brightness(1.1);
  }

  .ww-btn svg {
    transition: transform 0.3s ease;
  }

  .ww-btn:hover svg {
    transform: translateX(4px);
  }

  /* --- Lado Derecho: Timeline --- */
  .ww-timeline {
    position: relative;
  }

  .ww-step {
    position: relative;
    padding-left: 80px;
    margin-bottom: 48px;
  }

  .ww-step:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 749px) { 
    .ww-step { padding-left: 0; margin-bottom: 40px; } 
  }

  /* FIX LÍNEAS: Ahora usan height explícito y nacen del centro */
  .ww-step-line {
    position: absolute;
    left: 23px; /* Centrado en el círculo de 48px */
    top: 24px; /* Nace exactamente desde la mitad del círculo actual */
    height: calc(100% + 48px); /* Altura del bloque actual + los 48px de margen hasta el siguiente */
    width: 2px;
    z-index: 1; /* Por debajo del círculo */
  }

  /* El último paso tiene una línea que se desvanece y no llega al siguiente */
  .ww-step:last-child .ww-step-line {
    height: calc(100% - 24px); 
  }

  @media (max-width: 749px) { .ww-step-line { display: none; } }

  .ww-step-number {
    position: absolute;
    left: 0;
    top: 0;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: {{ section.settings.bg_color }}; /* Fondo sólido importante para tapar la línea */
    border: 2px solid {{ section.settings.gradient_start }};
    color: {{ section.settings.gradient_start }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 800;
    z-index: 2; /* Por encima de la línea */
  }

  @media (max-width: 749px) { .ww-step-number { display: none; } }

  .ww-step-content-wrapper {
    display: flex;
    gap: 24px;
    align-items: flex-start;
  }

  .ww-step-icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    background-color: rgba(99, 102, 241, 0.1);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.gradient_start }};
  }

  .ww-step-text h4 {
    font-size: 18px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: {{ section.settings.text_color }};
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .ww-step-text p {
    font-size: 15px;
    line-height: 1.6;
    color: #4b5563;
    margin: 0;
  }
</style>

<div class="why-work-{{ section.id }}">
  <div class="ww-container">
    <div class="ww-grid">
      
      <div class="ww-left-side">
        <div class="ww-title-wrapper">
          <h2 class="ww-title">
            {{ section.settings.title_1 }}<br/>
            <span class="ww-gradient-text">{{ section.settings.title_2 }}</span>
            {{ section.settings.title_3 }}
          </h2>
        </div>
        
        <div class="ww-desc">
          {{ section.settings.description }}
        </div>

        {% if section.settings.btn_text != blank %}
          <a href="{{ section.settings.btn_link }}" class="ww-btn">
            {{ section.settings.btn_text }}
            <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {% endif %}
      </div>

      <div class="ww-right-side">
        <div class="ww-timeline">
          
          {% for block in section.blocks %}
            
            {% comment %} 
              Lógica para obtener el color del siguiente bloque de forma segura
            {% endcomment %}
            {% assign next_index = forloop.index0 | plus: 1 %}
            {% if section.blocks[next_index] %}
              {% assign next_color = section.blocks[next_index].settings.step_color %}
            {% else %}
              {% assign next_color = 'transparent' %}
            {% endif %}

            <div class="ww-step" {{ block.shopify_attributes }}>
              
              <div class="ww-step-line" style="background-image: linear-gradient(to bottom, {{ block.settings.step_color }} 0%, {{ next_color }} 100%);"></div>

              <div class="ww-step-number" style="border-color: {{ block.settings.step_color }}; color: {{ block.settings.step_color }};">{{ forloop.index }}</div>
              
              <div class="ww-step-content-wrapper">
                <div class="ww-step-icon" style="background-color: {{ block.settings.step_color }}15; color: {{ block.settings.step_color }};">
                  {% if block.settings.custom_svg != blank %}
                    {{ block.settings.custom_svg }}
                  {% else %}
                    <svg width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
                  {% endif %}
                </div>
                
                <div class="ww-step-text">
                  <h4>{{ block.settings.title }}</h4>
                  <p>{{ block.settings.text }}</p>
                </div>
              </div>
            </div>
          {% endfor %}
          
        </div>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Por qué trabajar conmigo",
  "settings": [
    {
      "type": "header",
      "content": "Textos del Título"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "Línea 1",
      "default": "POR QUÉ"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "Línea 2 (Con Degradado)",
      "default": "TRABAJAR"
    },
    {
      "type": "text",
      "id": "title_3",
      "label": "Línea 3",
      "default": "CONMIGO"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Descripción",
      "default": "<p>Tu socio estratégico para el éxito digital. Más que un proveedor, soy una extensión de tu equipo.</p>"
    },
    {
      "type": "header",
      "content": "Botón"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texto del Botón",
      "default": "INICIA TU PROYECTO"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Enlace del Botón"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Fondo del Botón",
      "default": "#5b5fc7"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Texto del Botón",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Colores Generales"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de la Sección",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color de Textos Oscuros",
      "default": "#1e293b"
    },
    {
      "type": "color",
      "id": "gradient_start",
      "label": "Degradado Inicial (Índigo)",
      "default": "#6366f1"
    },
    {
      "type": "color",
      "id": "gradient_end",
      "label": "Degradado Final (Lavanda)",
      "default": "#a5b4fc"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Paso / Pilar",
      "limit": 4,
      "settings": [
        {
          "type": "color",
          "id": "step_color",
          "label": "Color del Icono y Número",
          "default": "#6366f1"
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Ícono SVG",
          "info": "Pega aquí el código HTML de tu SVG (<svg>...</svg>)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Título del paso",
          "default": "DISEÑO A LA MEDIDA DE TU MARCA"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción",
          "default": "Soluciones personalizadas que capturan tu esencia y conectan con tu audiencia ideal."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Por qué trabajar conmigo",
      "category": "Custom Sections",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "step_color": "#6366f1",
            "title": "DISEÑO A LA MEDIDA DE TU MARCA",
            "text": "Soluciones personalizadas que capturan tu esencia y conectan con tu audiencia ideal."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_color": "#10b981",
            "title": "PROCESO DE DESARROLLO EFICIENTE",
            "text": "Metodología ágil y probada para entregar proyectos a tiempo, con el mejor rendimiento técnico."
          }
        },
        {
          "type": "step",
          "settings": {
            "step_color": "#a5b4fc",
            "title": "ACCESO A EXPERIENCIA MULTIDISCIPLINARIA",
            "text": "Especialistas trabajando en sinergia para lograr un resultado integral y rentable."
          }
        }
      ]
    }
  ]
}
{% endschema %}