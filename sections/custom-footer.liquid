<style>
  .fa-custom-footer {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: 80px 0 20px;
    border-top-left-radius: 80px;
    border-top-right-radius: 80px;
    margin-top: 40px;
  }
  
  .fa-custom-footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }
  
  @media (min-width: 768px) {
    .fa-custom-footer-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 990px) {
    .fa-custom-footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 30px;
    }
  }

  .fa-footer-brand {
    padding-right: 20px;
  }
  
  .fa-footer-logo {
    max-width: 200px;
    height: auto;
    margin-bottom: 20px;
    display: block;
  }
  
  .fa-footer-desc {
    font-size: 1.4rem;
    line-height: 1.6;
    margin-bottom: 25px;
    opacity: 0.9;
  }
  
  .fa-social-icons {
    display: flex;
    gap: 15px;
  }
  
  .fa-social-icon {
    width: 40px;
    height: 40px;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.text_color }};
    text-decoration: none;
    transition: background-color 0.3s ease;
  }
  
  .fa-social-icon:hover {
    background-color: rgba(255, 255, 255, 0.25);
  }
  
  .fa-social-icon svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
  
  .fa-footer-title {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 25px;
    margin-top: 0;
    color: inherit;
  }
  
  .fa-footer-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .fa-footer-menu li {
    margin-bottom: 15px;
  }
  
  .fa-footer-menu a {
    text-decoration: none;
    color: inherit;
    font-size: 1.4rem;
    opacity: 0.8;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: opacity 0.3s ease;
  }
  
  .fa-footer-menu a:hover {
    opacity: 1;
  }
  
  .fa-footer-menu a svg {
    width: 12px;
    height: 12px;
  }
  
  /* NUEVO CONTENEDOR PARA APILAR LAS INSIGNIAS */
  .fa-footer-badges-container {
    display: flex;
    flex-direction: column; /* Apila los elementos hacia abajo */
    gap: 15px; /* Espacio entre cada insignia */
    align-self: start; /* ESTO EVITA QUE SE ESTIRE EN ESCRITORIO */
    margin-top: 10px;
  }

  /* ESTILOS CORREGIDOS DE LA INSIGNIA */
  .fa-footer-badge {
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: #ffffff; 
    border-radius: 50px;       
    padding: 12px 25px;       
    width: fit-content;        
  }
  
  .fa-footer-badge img {
    max-width: 160px;         
    height: auto;
    display: block;
    object-fit: contain;
  }
  
  .fa-footer-bottom {
    margin-top: 60px;
    padding-top: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.3);
    text-align: center;
  }
  
  .fa-footer-bottom p {
    margin: 0;
    font-size: 1.3rem;
    opacity: 0.8;
  }
</style>

<div class="fa-custom-footer">
  <div class="page-width">
    <div class="fa-custom-footer-grid">
      
      <div class="fa-footer-brand">
        {% if section.settings.logo_url != blank %}
          <img src="{{ section.settings.logo_url }}" alt="Logo" class="fa-footer-logo" loading="lazy">
        {% endif %}
        
        <div class="fa-footer-desc">
          {{ section.settings.description }}
        </div>
        
        <div class="fa-social-icons">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" target="_blank" class="fa-social-icon" aria-label="Instagram">
              <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          {% endif %}
          
          {% if section.settings.tiktok_url != blank %}
            <a href="{{ section.settings.tiktok_url }}" target="_blank" class="fa-social-icon" aria-label="TikTok">
              <svg viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
            </a>
          {% endif %}
          
          {% if section.settings.whatsapp_url != blank %}
            <a href="{{ section.settings.whatsapp_url }}" target="_blank" class="fa-social-icon" aria-label="WhatsApp">
              <svg viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.88-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.347-.272.297-1.04 1.016-1.04 2.479 0 1.463 1.065 2.876 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <div class="fa-footer-col">
        {% if section.settings.menu_1_title != blank %}
          <h3 class="fa-footer-title">{{ section.settings.menu_1_title }}</h3>
        {% endif %}
        {% if section.settings.menu_1 != blank %}
          <ul class="fa-footer-menu">
            {% for link in linklists[section.settings.menu_1].links %}
              <li>
                <a href="{{ link.url }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  {{ link.title }}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      <div class="fa-footer-col">
        {% if section.settings.menu_2_title != blank %}
          <h3 class="fa-footer-title">{{ section.settings.menu_2_title }}</h3>
        {% endif %}
        {% if section.settings.menu_2 != blank %}
          <ul class="fa-footer-menu">
            {% for link in linklists[section.settings.menu_2].links %}
              <li>
                <a href="{{ link.url }}">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
                  {{ link.title }}
                </a>
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>

      <div class="fa-footer-badges-container">
        
        {% if section.settings.partner_url != blank %}
          <div class="fa-footer-badge">
            <img src="{{ section.settings.partner_url }}" alt="Shopify Partners" loading="lazy">
          </div>
        {% endif %}
        
        {% if section.settings.partner_url_2 != blank %}
          <div class="fa-footer-badge">
            <img src="{{ section.settings.partner_url_2 }}" alt="Insignia 2" loading="lazy">
          </div>
        {% endif %}
        
        {% if section.settings.partner_url_3 != blank %}
          <div class="fa-footer-badge">
            <img src="{{ section.settings.partner_url_3 }}" alt="Insignia 3" loading="lazy">
          </div>
        {% endif %}
        
        {% if section.settings.partner_url_4 != blank %}
          <div class="fa-footer-badge">
            <img src="{{ section.settings.partner_url_4 }}" alt="Insignia 4" loading="lazy">
          </div>
        {% endif %}

      </div>
      </div>

    <div class="fa-footer-bottom">
      <p>{{ section.settings.copyright_text }}</p>
    </div>
  </div>
</div>

{% schema %}
