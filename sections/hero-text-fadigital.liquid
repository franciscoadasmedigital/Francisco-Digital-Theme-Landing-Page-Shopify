{% comment %}
  Custom Hero Section with Typewriter Effect and Floating Elements.
  Designed for Shopify Dawn Theme.
  Version: Centered Text Only (No Video).
{% endcomment %}

<style>
  :root {
    --hero-indigo: {{ section.settings.primary_color }};
    --hero-emerald: {{ section.settings.secondary_color }};
    --hero-text: {{ section.settings.text_color }};
    --hero-bg: {{ section.settings.bg_color }};
    /* Paleta de colores para el efecto de aurora */
    --aurora-1: rgba(79, 70, 229, 0.1);
    --aurora-2: rgba(16, 185, 129, 0.1);
    --aurora-3: rgba(6, 182, 212, 0.08);
    --aurora-4: rgba(236, 72, 153, 0.05);
  }

  .hero-wrapper-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background-color: var(--hero-bg);
    background: radial-gradient(circle at 10% 20%, var(--aurora-1) 0%, transparent 50%), radial-gradient(circle at 80% 80%, var(--aurora-2) 0%, transparent 50%), var(--hero-bg);
    
    /* FIX ESPACIO EN BLANCO: Margen negativo para subir y padding compensatorio */
    margin-top: -{{ section.settings.margin_top_offset }}px;
    padding-top: calc(60px + {{ section.settings.margin_top_offset }}px);
    padding-bottom: 60px;
    padding-left: 20px;
    padding-right: 20px;
    
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    min-height: 600px;
    display: flex;
    align-items: center;
    z-index: 1; /* Se mantiene bajo para quedar detrás del header */
  }

  @media (min-width: 990px) {
    .hero-wrapper-{{ section.id }} { 
      padding-top: calc(80px + {{ section.settings.margin_top_offset }}px);
      padding-bottom: 80px;
      padding-left: 40px;
      padding-right: 40px;
    }
  }

  .hero-container {
    max-width: 1200px;
    width: 100%;
    min-height: 538.42px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 10;
  }

  @media (min-width: 990px) {
    .hero-container {
      height: 538.42px;
    }
  }

  /* Blobs de fondo para el efecto de aurora */
  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(150px);
    opacity: 0.15;
    pointer-events: none;
    z-index: 1;
    animation: blob-anim 15s infinite alternate ease-in-out;
  }

  .blob-1 { top: -20%; left: -20%; width: 50vw; height: 50vw; background: var(--hero-indigo); }
  .blob-2 { top: 30%; right: -10%; width: 40vw; height: 40vw; background: var(--hero-emerald); animation-delay: 2s; }
  .blob-3 { bottom: -10%; left: 30%; width: 30vw; height: 30vw; background: var(--hero-indigo); animation-delay: 4s; }
  .blob-4 { top: 50%; left: 10%; width: 20vw; height: 20vw; background: #06b6d4; animation-delay: 6s; }
  .blob-5 { top: 70%; right: 20%; width: 25vw; height: 25vw; background: #ec4899; animation-delay: 8s; }

  @keyframes blob-anim {
    0% { transform: translate(0, 0) scale(1) rotate(0); }
    33% { transform: translate(50px, -70px) scale(1.1) rotate(10deg); }
    66% { transform: translate(-30px, 30px) scale(0.95) rotate(-10deg); }
    100% { transform: translate(10px, -10px) scale(1.05) rotate(0); }
  }

  /* Texto e Información centrada */
  .hero-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    max-width: 850px; /* Limita el ancho para que el texto se vea bien distribuido */
    margin: 0 auto;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: 100px;
    color: var(--hero-indigo);
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 20px;
    width: fit-content;
  }

  .hero-title {
    font-size: 38px;
    line-height: 1.1;
    font-weight: 800;
    color: var(--hero-text);
    margin-bottom: 24px;
    margin-top: 0;
    min-height: 120px;
    display: block;
  }

  @media (min-width: 750px) { .hero-title { font-size: 52px; min-height: 160px; } }
  @media (min-width: 990px) { .hero-title { font-size: 64px; min-height: 180px; } }

  .gradient-text {
    background: linear-gradient(to right, var(--hero-indigo), var(--hero-emerald));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline;
  }

  .cursor {
    display: inline-block;
    color: var(--hero-indigo);
    font-weight: 300;
    margin-left: 4px;
    animation: blink 0.8s infinite;
  }

  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .hero-desc {
    font-size: 17px;
    color: #4b5563;
    line-height: 1.6;
    margin-bottom: 30px;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    margin-top: 0;
  }
  
  @media (min-width: 990px) { .hero-desc { font-size: 20px; } }

  .hero-btns { 
    display: flex; 
    flex-direction: column; 
    gap: 16px; 
    width: 100%;
    justify-content: center;
    align-items: center;
  }
  @media (min-width: 600px) { 
    .hero-btns { 
      flex-direction: row; 
    } 
  }

  .btn-primary {
    padding: 14px 28px;
    background: #0f172a;
    color: white !important;
    text-decoration: none;
    border-radius: 100px;
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    box-shadow: 0 10px 25px -5px rgba(15, 23, 42, 0.2);
    transition: all 0.3s;
    width: 100%;
  }
  @media (min-width: 600px) { .btn-primary { width: auto; } }

  .btn-primary:hover { background: #1e293b; transform: translateY(-2px); }

  .btn-secondary {
    padding: 14px 28px;
    background: white;
    color: #374151 !important;
    text-decoration: none;
    border: 2px solid #e5e7eb;
    border-radius: 100px;
    font-weight: 600;
    text-align: center;
    transition: all 0.3s;
    width: 100%;
  }
  @media (min-width: 600px) { .btn-secondary { width: auto; } }

  .btn-secondary:hover { border-color: #d1d5db; background: #f9fafb; }

  /* SISTEMA DE FIGURAS FLOTANTES ABUNDANTES */
  .shape-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    overflow: hidden;
  }

  .float-element {
    position: absolute;
    color: rgba(99, 102, 241, 0.15);
  }

  .anim-float { animation: float-anim 8s ease-in-out infinite; }
  .anim-float-slow { animation: float-anim 12s ease-in-out infinite; }
  .anim-float-reverse { animation: float-anim-rev 10s ease-in-out infinite; }
  .anim-spin { animation: spin-anim 15s linear infinite; }
  .anim-spin-slow { animation: spin-anim-rev 25s linear infinite; }
  .anim-pulse { animation: pulse-anim 6s ease-in-out infinite; }

  @keyframes float-anim {
    0%, 100% { transform: translateY(0) rotate(0); }
    50% { transform: translateY(-30px) rotate(15deg); }
  }
  @keyframes float-anim-rev {
    0%, 100% { transform: translate(0, 0) rotate(0); }
    50% { transform: translate(20px, 25px) rotate(-15deg); }
  }
  @keyframes spin-anim {
    0% { transform: rotate(0deg) translateY(0); }
    50% { transform: rotate(180deg) translateY(-15px); }
    100% { transform: rotate(360deg) translateY(0); }
  }
  @keyframes spin-anim-rev {
    0% { transform: rotate(360deg) translateY(0); }
    50% { transform: rotate(180deg) translateY(20px); }
    100% { transform: rotate(0deg) translateY(0); }
  }
  @keyframes pulse-anim {
    0%, 100% { transform: scale(1) translateY(0); opacity: 0.15; }
    50% { transform: scale(1.2) translateY(-10px); opacity: 0.3; }
  }
</style>

<div class="hero-wrapper-{{ section.id }}">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
  <div class="blob blob-4"></div>
  <div class="blob blob-5"></div>

  <div class="shape-layer">
    <div class="float-element anim-float-reverse" style="top: 15%; right: 12%; opacity: 0.45; animation-delay: 1s;">
      <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSfAG1sZJEG7XK4uH6271f8HKn458g1T4nZxQ&s" alt="Shopify Icon" style="width: 50px; height: 50px; object-fit: contain; mix-blend-mode: multiply; border-radius: 8px;">
    </div>
    <div class="float-element anim-float-slow" style="bottom: 25%; left: 8%; color: rgba(37, 99, 235, 0.2); animation-delay: 2.5s;">
      <svg width="45" height="45" viewBox="0 0 512 512" fill="currentColor"><path d="M61.7 169.4l101.5 278C92.2 413 43.3 340.2 43.3 256c0-30.9 6.6-60.1 18.4-86.6zm337.9 75.9c0-26.3-9.4-44.5-17.5-58.7-10.8-17.5-20.9-32.4-20.9-49.9 0-19.6 14.8-37.8 35.7-37.8.9 0 1.8.1 2.8.2-37.9-34.7-88.3-55.9-143.7-55.9-74.3 0-139.7 38.1-177.8 95.9 5 .2 9.7.3 13.7.3 22.2 0 56.7-2.7 56.7-2.7 11.5-.7 12.8 16.2 1.4 17.5 0 0-11.5 1.3-24.3 2l77.5 230.4L249.8 247l-33.1-90.8c-11.5-.7-22.3-2-22.3-2-11.5-.7-10.1-18.2 1.3-17.5 0 0 35.1 2.7 56 2.7 22.2 0 56.7-2.7 56.7-2.7 11.5-.7 12.8 16.2 1.4 17.5 0 0-11.5 1.3-24.3 2l76.9 228.7 21.2-70.9c9-29.4 16-50.5 16-68.7zm-139.9 29.3l-63.8 185.5c19.1 5.6 39.2 8.7 60.1 8.7 24.8 0 48.5-4.3 70.6-12.1-.6-1.1-1.6-2.4-3-4.1l-63.9-178zM256 0C114.6 0 0 114.6 0 256s114.6 256 256 256 256-114.6 256-256S397.4 0 256 0zm0 476.3c-121.5 0-220.3-98.8-220.3-220.3S134.5 35.7 256 35.7 476.3 134.5 476.3 256 377.5 476.3 256 476.3z"/></svg>
    </div>
