      <svg width="50" height="50" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="6 6"><circle cx="25" cy="25" r="20"/></svg>
    </div>
    <div class="float-element anim-spin" style="top: 45%; left: 5%; color: rgba(236, 72, 153, 0.15); animation-duration: 20s;">
      <svg width="35" height="35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/></svg>
    </div>
    <div class="float-element anim-float-reverse" style="bottom: 40%; right: 45%; animation-delay: 2s;">
      <svg width="30" height="30" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="5" width="20" height="20" rx="4"/></svg>
    </div>
    <div class="float-element anim-spin" style="top: 25%; right: 5%;">
      <svg width="25" height="25" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="2"><polygon points="20,0 40,35 0,35"/></svg>
    </div>
    <div class="float-element anim-float" style="top: 60%; right: 8%; animation-delay: 5s;">
      <svg width="50" height="15" viewBox="0 0 100 20" fill="none" stroke="currentColor" stroke-width="3"><line x1="0" y1="10" x2="100" y2="10" stroke-dasharray="10 10"/></svg>
    </div>
    <div class="float-element anim-pulse" style="bottom: 15%; left: 40%; animation-delay: 1.5s;">
      <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="12" y1="4" x2="12" y2="20"></line><line x1="4" y1="12" x2="20" y2="12"></line></svg>
