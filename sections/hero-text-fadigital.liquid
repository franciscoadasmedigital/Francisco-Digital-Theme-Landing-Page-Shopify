      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
    </div>
    <div class="float-element anim-pulse" style="top: 15%; right: 35%; color: rgba(236, 72, 153, 0.2); animation-delay: 0.5s;">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0l2.5 8.5L23 11l-8.5 2.5L12 22l-2.5-8.5L1 11l8.5-2.5z"/></svg>
    </div>
    <div class="float-element anim-pulse" style="bottom: 30%; right: 5%; color: rgba(6, 182, 212, 0.2); animation-delay: 4s;">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0l2.5 8.5L23 11l-8.5 2.5L12 22l-2.5-8.5L1 11l8.5-2.5z"/></svg>
    </div>
    <div class="float-element anim-spin" style="top: 8%; right: 25%; animation-duration: 25s;">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" transform="rotate(45 12 12)"/></svg>
    </div>
    <div class="float-element anim-float" style="bottom: 35%; left: 5%; animation-delay: 4s;">
      <svg width="40" height="15" viewBox="0 0 40 15" fill="none" stroke="currentColor" stroke-width="2" stroke-linejoin="round"><polyline points="0,10 10,2 20,10 30,2 40,10"/></svg>
    </div>
    <div class="float-element anim-pulse" style="bottom: 5%; left: 20%; animation-delay: 2.5s;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><circle cx="4" cy="4" r="2"/><circle cx="12" cy="4" r="2"/><circle cx="20" cy="4" r="2"/><circle cx="4" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="20" cy="12" r="2"/><circle cx="4" cy="20" r="2"/><circle cx="12" cy="20" r="2"/><circle cx="20" cy="20" r="2"/></svg>
    </div>
  </div>

  <div class="hero-container">
    <div class="hero-content">
      <div class="hero-badge">
        <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M5.52.359A.5.5 0 0 1 6 0h4a.5.5 0 0 1 .474.658L8.694 6H12.5a.5.5 0 0 1 .395.807l-7 9a.5.5 0 0 1-.873-.454L6.823 9H3.5a.5.5 0 0 1-.48-.641l2.5-8z"/></svg>
        <span>{{ section.settings.badge_text }}</span>
      </div>

      <h1 class="hero-title">
        {{ section.settings.title_prefix }}
        <span class="gradient-text" id="typewriter-{{ section.id }}"></span><span class="cursor">|</span>
      </h1>

      <p class="hero-desc">
        {{ section.settings.description | replace: 'Shopify', '<span style="color: #059669; font-weight: 600;">Shopify</span>' | replace: 'WordPress', '<span style="color: #2563EB; font-weight: 600;">WordPress</span>' }}
      </p>

      <div class="hero-btns">
        <a href="{{ section.settings.primary_btn_link }}" class="btn-primary">
          {{ section.settings.primary_btn_text }}
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a href="{{ section.settings.secondary_btn_link }}" class="btn-secondary">
          {{ section.settings.secondary_btn_text }}
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // --- LÓGICA DEL TYPEWRITER ---
    const el = document.getElementById('typewriter-{{ section.id }}');
    if (el) {
      const words = "{{ section.settings.words }}".split(',').map(w => w.trim());
      let wordIndex = 0;
      let charIndex = 0;
      let isDeleting = false;
      let typeSpeed = 150;

      function type() {
        const current = words[wordIndex];
        if (isDeleting) {
          el.textContent = current.substring(0, charIndex - 1);
          charIndex--;
          typeSpeed = 50;
        } else {
          el.textContent = current.substring(0, charIndex + 1);
          charIndex++;
          typeSpeed = 100;
        }

        if (!isDeleting && charIndex === current.length) {
          isDeleting = true;
          typeSpeed = 2500;
        } else if (isDeleting && charIndex === 0) {
          isDeleting = false;
          wordIndex = (wordIndex + 1) % words.length;
          typeSpeed = 500;
        }
        setTimeout(type, typeSpeed);
      }
      if (words.length > 0) type();
    }
  });
</script>

{% schema %}
{
  "name": "Hero Texto FAdigital",
  "settings": [
    {
      "type": "header",
      "content": "Ajuste de Diseño"
    },
    {
      "type": "range",
      "id": "margin_top_offset",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "label": "Subir sección detrás del menú",
      "default": 100,
      "info": "Ajusta este valor para eliminar el espacio en blanco superior y subir el fondo."
    },
    {
      "type": "header",
      "content": "Colores"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Color Primario (Indigo)",
      "default": "#4f46e5"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Color Secundario (Esmeralda)",
      "default": "#10b981"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de sección",
      "default": "#f8fafc"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color del título",
      "default": "#0f172a"
    },
    {
      "type": "header",
      "content": "Contenido de Texto"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texto del Badge",
      "default": "Expertos en E-commerce y Desarrollo Web"
    },
    {
      "type": "text",
      "id": "title_prefix",
      "label": "Prefijo del título",
      "default": "Transformamos tu visión en una "
    },
    {
      "type": "textarea",
      "id": "words",
      "label": "Palabras para el efecto (separadas por coma)",
      "default": "máquina de ventas., tienda de éxito., marca imparable."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción",
      "default": "Diseñamos y desarrollamos tiendas online en Shopify y sitios web escalables en WordPress. Enfocados en la experiencia de usuario y la conversión."
    },
    {
      "type": "header",
      "content": "Botones"
    },
    {
      "type": "text",
      "id": "primary_btn_text",
      "label": "Texto Botón Principal",
      "default": "Ver Casos de Éxito"
    },
    {
      "type": "url",
      "id": "primary_btn_link",
      "label": "Link Botón Principal"
    },
    {
      "type": "text",
      "id": "secondary_btn_text",
      "label": "Texto Botón Secundario",
      "default": "Nuestros Servicios"
    },
    {
      "type": "url",
      "id": "secondary_btn_link",
      "label": "Link Botón Secundario"
    }
  ],
  "presets": [
    {
      "name": "Hero Texto FAdigital"
    }
  ]
}
{% endschema %}