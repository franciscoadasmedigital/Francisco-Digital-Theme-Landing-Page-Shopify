{% comment %}
  Sección de Tarjetas de Servicios con colores específicos y diseño responsivo.
  Diseñado para el tema Shopify Dawn.
{% endcomment %}

<style>
  .services-cards-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .sc-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .sc-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 60px auto;
  }

  .sc-title {
    font-size: 36px;
    font-weight: 800;
    color: #1e293b;
    margin-bottom: 20px;
    letter-spacing: -0.02em;
  }

  @media (min-width: 750px) {
    .sc-title { font-size: 48px; }
  }

  .sc-title-accent {
    position: relative;
    display: inline-block;
    background: linear-gradient(to right, #4f46e5, #10b981);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .sc-title-underline {
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(to right, #4f46e5, #10b981);
    border-radius: 10px;
    transform-origin: left;
    animation: sc-underline-pulse 4s ease-in-out infinite;
  }

  @keyframes sc-underline-pulse {
    0% { transform: scaleX(0); transform-origin: 0% 50%; }
    40% { transform: scaleX(1); transform-origin: 0% 50%; }
    50% { transform: scaleX(1); transform-origin: 100% 50%; }
    90% { transform: scaleX(0); transform-origin: 100% 50%; }
    100% { transform: scaleX(0); transform-origin: 0% 50%; }
  }

  .sc-subtitle {
    font-size: 18px;
    color: #64748b;
    line-height: 1.6;
  }

  .sc-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }

  @media (min-width: 750px) {
    .sc-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 990px) {
    .sc-grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* Estilos de las Tarjetas */
  .service-card {
    border-radius: 24px;
    padding: 40px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid transparent;
  }

  .service-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.06);
  }

  .sc-icon-box {
    width: 60px;
    height: 60px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 30px;
    color: white;
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
  }

  .sc-card-title {
    font-size: 24px;
    font-weight: 800;
    color: #1e293b;
    margin-bottom: 16px;
    letter-spacing: -0.01em;
  }

  .sc-card-desc {
    font-size: 15px;
    line-height: 1.6;
    color: #475569;
    margin-bottom: 30px;
    flex-grow: 1;
  }

  .sc-features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sc-feature-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 14px;
    font-weight: 500;
    color: #475569;
  }

  .sc-check {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
  }
</style>

<div id="precios" class="services-cards-{{ section.id }}">
  <div class="sc-container">
    
    <div class="sc-header">
      <h2 class="sc-title">
        {{ section.settings.title_prefix }}
        <span class="sc-title-accent">
          {{ section.settings.title_accent }}
          <span class="sc-title-underline"></span>
        </span>
      </h2>
      <p class="sc-subtitle">{{ section.settings.description }}</p>
    </div>

    <div class="sc-grid">
      {% for block in section.blocks %}
        <div class="service-card" {{ block.shopify_attributes }} style="background-color: {{ block.settings.card_bg }}; border-color: {{ block.settings.accent_color }}22;">
          
          <div class="sc-icon-box" style="background-color: {{ block.settings.accent_color }};">
            {% if block.settings.custom_svg != blank %}
              {{ block.settings.custom_svg }}
            {% else %}
              <svg width="28" height="28" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            {% endif %}
          </div>

          <h3 class="sc-card-title">{{ block.settings.title }}</h3>
          <p class="sc-card-desc">{{ block.settings.text }}</p>

          <ul class="sc-features-list">
            {% assign features = block.settings.features | newline_to_br | split: '<br />' %}
            {% for feature in features %}
              {% if feature != blank %}
                <li class="sc-feature-item">
                  <svg class="sc-check" style="color: {{ block.settings.accent_color }};" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M5 13l4 4L19 7"/>
                  </svg>
                  <span>{{ feature | strip }}</span>
                </li>
              {% endif %}
            {% endfor %}
          </ul>

        </div>
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Tarjetas de Servicios Pro",
  "settings": [
    {
      "type": "header",
      "content": "Cabecera de Sección"
    },
    {
      "type": "text",
      "id": "title_prefix",
      "label": "Prefijo del Título",
      "default": "Nuestros"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Palabra Animada",
      "default": "Servicios"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción Superior",
      "default": "No hacemos simples páginas web. Construimos herramientas estratégicas para el crecimiento de tu negocio."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de Sección",
      "default": "#f8fafc"
    },
    {
      "type": "header",
      "content": "Espaciado"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Superior",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Inferior",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Servicio",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título",
          "default": "E-commerce Shopify"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Descripción",
          "default": "Tiendas online optimizadas para vender más."
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "Beneficios (uno por línea)",
          "default": "Diseño UI/UX orientado a ventas\nMigración de plataformas\nPasarelas de pago"
        },
        {
          "type": "html",
          "id": "custom_svg",
          "label": "Icono SVG (opcional)",
          "info": "Pega aquí el código <svg>..."
        },
        {
          "type": "color",
          "id": "card_bg",
          "label": "Fondo de Tarjeta",
          "default": "#d1fae5"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Color de Acento",
          "default": "#10b981"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tarjetas de Servicios Pro",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "title": "E-commerce Shopify",
            "card_bg": "#d1fae5",
            "accent_color": "#10b981",
            "text": "Tiendas online optimizadas para vender más. Desde la configuración inicial hasta un diseño completamente a medida."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Landing Pages WP",
            "card_bg": "#dbeafe",
            "accent_color": "#2563eb",
            "text": "Páginas de aterrizaje persuasivas, diseñadas específicamente para captar leads o vender un solo producto."
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Webs Corporativas",
            "card_bg": "#e0e7ff",
            "accent_color": "#4f46e5",
            "text": "Sitios web institucionales en WordPress, completamente autoadministrables y preparados para Google."
          }
        }
      ]
    }
  ]
}
{% endschema %}