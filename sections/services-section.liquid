{% comment %}
  Sección de Servicios Personalizada para el tema Dawn de Shopify.
  Incluye diseño de 3 columnas, íconos personalizables, lista de beneficios y animación de subrayado.
{% endcomment %}

<style>
  .services-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .services-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 60px auto;
    padding: 0 20px;
  }

  .services-title {
    font-size: 32px;
    font-weight: 800;
    color: #1e293b;
    margin-bottom: 20px;
  }

  @media (min-width: 750px) {
    .services-title { font-size: 48px; }
  }

  .services-title-accent {
    position: relative;
    display: inline-block;
    background: linear-gradient(to right, {{ section.settings.primary_color }}, {{ section.settings.secondary_color }});
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .services-title-underline {
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(to right, {{ section.settings.primary_color }}, {{ section.settings.secondary_color }});
    border-radius: 10px;
    transform-origin: left;
    animation: underline-pulse 4s ease-in-out infinite;
  }

  @keyframes underline-pulse {
    0% { transform: scaleX(0); transform-origin: 0% 50%; }
    40% { transform: scaleX(1); transform-origin: 0% 50%; }
    50% { transform: scaleX(1); transform-origin: 100% 50%; }
    90% { transform: scaleX(0); transform-origin: 100% 50%; }
    100% { transform: scaleX(0); transform-origin: 0% 50%; }
  }

  .services-subtitle {
    font-size: 18px;
    color: #64748b;
    line-height: 1.6;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  @media (min-width: 750px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 990px) {
    .services-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .service-card {
    background: white;
    border-radius: 24px;
    padding: 40px;
    border: 1px solid #e2e8f0;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .service-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);
    border-color: {{ section.settings.primary_color }}44;
  }

  .service-icon-wrapper {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    color: white;
  }

  .service-card-title {
    font-size: 24px;
    font-weight: 700;
    color: #1e293b;
    margin-bottom: 16px;
  }

  .service-card-desc {
    font-size: 15px;
    color: #64748b;
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .service-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 14px;
    color: #475569;
  }

  .feature-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    margin-top: 2px;
  }
</style>

<div class="services-section-{{ section.id }}">
  <div class="services-header">
    <h2 class="services-title">
      {{ section.settings.title_start }}
      <span class="services-title-accent">
        {{ section.settings.title_accent }}
        <span class="services-title-underline"></span>
      </span>
    </h2>
    <div class="services-subtitle">
      {{ section.settings.description }}
    </div>
  </div>

  <div class="services-grid">
    {% for block in section.blocks %}
      <div class="service-card" {{ block.shopify_attributes }}>
        <div class="service-icon-wrapper" style="background-color: {{ block.settings.icon_bg }};">
          {% if block.settings.custom_icon != blank %}
            <img src="{{ block.settings.custom_icon | img_url: '40x' }}" alt="" width="28" height="28">
          {% else %}
            <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
          {% endif %}
        </div>
        
        <h3 class="service-card-title">{{ block.settings.title }}</h3>
        <p class="service-card-desc">{{ block.settings.description }}</p>
        
        <ul class="service-features">
          {% assign features = block.settings.features | newline_to_br | split: '<br />' %}
          {% for feature in features %}
            {% if feature != blank %}
              <li class="feature-item">
                <svg class="feature-icon" style="color: {{ section.settings.secondary_color }};" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path d="M5 13l4 4L19 7"/>
                </svg>
                <span>{{ feature | strip }}</span>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Nuestros Servicios Pro",
  "settings": [
    {
      "type": "header",
      "content": "Encabezado de Sección"
    },
    {
      "type": "text",
      "id": "title_start",
      "label": "Inicio del Título",
      "default": "Nuestros"
    },
    {
      "type": "text",
      "id": "title_accent",
      "label": "Palabra Animada",
      "default": "Servicios"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Descripción Superior",
      "default": "No hacemos simples páginas web. Construimos herramientas estratégicas para el crecimiento de tu negocio."
    },
    {
      "type": "header",
      "content": "Estilos y Colores"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Color Primario (Indigo)",
      "default": "#4f46e5"
    },
    {
      "type": "color",
      "id": "secondary_color",
      "label": "Color Secundario (Emerald)",
      "default": "#10b981"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Color de Fondo",
      "default": "#f8fafc"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espaciado Superior",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Espaciado Inferior",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Servicio",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título del Servicio",
          "default": "E-commerce Shopify"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción del Servicio",
          "default": "Tiendas online optimizadas para vender más. Desde la configuración inicial hasta un diseño completamente a medida."
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "Lista de Beneficios (uno por línea)",
          "default": "Diseño UI/UX orientado a ventas\nMigración de otras plataformas\nIntegración de pasarelas de pago\nOptimización de Checkout"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Ícono Personalizado (Opcional)"
        },
        {
          "type": "color",
          "id": "icon_bg",
          "label": "Color de Fondo del Ícono",
          "default": "#4f46e5"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuestros Servicios Pro",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "title": "E-commerce Shopify",
            "icon_bg": "#10b981"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Landing Pages WP",
            "icon_bg": "#4f46e5"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Webs Corporativas",
            "icon_bg": "#6366f1"
          }
        }
      ]
    }
  ]
}
{% endschema %}