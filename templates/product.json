        "custom_liquid_Jzzrqz": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% comment %}\nFV - Google Reviews Infinite Marquee (NO achica multimedia en desktop)\n- Track en position:absolute para que NO afecte el grid/flex del producto\n- Viewport mantiene tamaño normal y el track se anima por dentro\n- Usa tus mismas reseñas + avatares\n{% endcomment %}\n\n<style>\n  /* ====== AISLADOR: esto evita que el bloque empuje el layout del producto ====== */\n  .fv-grm-safe{\n    display:block;\n    width:100%;\n    min-width:0 !important; /* CLAVE para grid items */\n    max-width:100%;\n    box-sizing:border-box;\n    contain: layout paint;   /* evita “side effects” en layout */\n  }\n\n  .fv-grm-wrap{\n    width:100%;\n    min-width:0 !important;\n    max-width:100%;\n    margin: 18px 0 0;\n    font-family: inherit;\n    box-sizing: border-box;\n  }\n\n  /* Barra superior */\n  .fv-grm-top{\n    display:flex;\n    align-items:center;\n    justify-content:flex-start;\n    gap:12px;\n    padding: 12px 14px;\n    border: 1px solid #e9e9e9;\n    border-radius: 14px;\n    background: #ffffff;\n    box-shadow: 0 6px 18px rgba(0,0,0,.05);\n    margin-bottom: 12px;\n    min-width:0 !important;\n  }\n  .fv-grm-glogo{ width:20px; height:20px; flex:0 0 20px; display:block; }\n  .fv-grm-title{ font-weight:700; font-size:16px; line-height:1.2; color:#111; }\n  .fv-grm-meta{\n    display:flex;\n    align-items:center;\n    gap:10px;\n    margin-left: 6px;\n    flex-wrap: wrap;\n    min-width:0;\n  }\n  .fv-grm-rating{ font-weight:700; font-size:16px; color:#111; }\n  .fv-grm-stars{ color:#fbbc05; letter-spacing:1px; font-size:16px; line-height:1; }\n  .fv-grm-count{ color:#666; font-size:14px; }\n\n  /* ====== VIEWPORT ====== */\n  .fv-grm-marquee{\n    position: relative;\n    overflow: hidden;\n    border-radius: 16px;\n    max-width:100%;\n    min-width:0 !important;\n    background: transparent;\n  }\n\n  /* ====== TRACK ABSOLUTO ====== */\n  .fv-grm-track{\n    position:absolute;\n    left:0;\n    top:0;\n    display:flex;\n    gap:16px;\n    will-change: transform;\n    transform: translate3d(0,0,0);\n    animation: fv-grm-scroll var(--fv-grm-speed, 28s) linear infinite;\n  }\n\n  .fv-grm-group{\n    display:flex;\n    gap:16px;\n  }\n\n  /* Tarjetas */\n  .fv-grm-card{\n    width: 340px;\n    min-width: 340px;\n    background:#fff;\n    border:1px solid #e7e7e7;\n    border-radius: 14px;\n    box-shadow: 0 6px 18px rgba(0,0,0,.05);\n    padding: 14px 14px 16px;\n    box-sizing:border-box;\n  }\n\n  .fv-grm-head{ display:flex; align-items:center; gap:10px; margin-bottom:8px; }\n  .fv-grm-avatar{\n    width:40px; height:40px; border-radius:999px; object-fit:cover;\n    border:1px solid #e0e0e0; flex:0 0 40px; display:block;\n  }\n  .fv-grm-name{ font-weight:700; font-size:14px; color:#111; line-height:1.2; }\n  .fv-grm-stars-small{ color:#fbbc05; font-size:16px; letter-spacing:1px; line-height:1; margin-top:2px; }\n  .fv-grm-text{\n    margin: 8px 0 0;\n    font-size:14px;\n    color:#333;\n    line-height:1.45;\n    display:-webkit-box;\n    -webkit-line-clamp: 3;\n    -webkit-box-orient: vertical;\n    overflow:hidden;\n  }\n\n  @keyframes fv-grm-scroll{\n    from{ transform: translate3d(0,0,0); }\n    to{ transform: translate3d(calc(-1 * var(--fv-grm-distance, 1000px)), 0, 0); }\n  }\n\n  @media (max-width: 768px){\n    .fv-grm-title{ font-size:15px; }\n    .fv-grm-rating{ font-size:15px; }\n    .fv-grm-stars{ font-size:15px; }\n    .fv-grm-card{ width: 300px; min-width: 300px; }\n  }\n\n  @media (prefers-reduced-motion: reduce){\n    .fv-grm-track{ animation:none !important; position:static; }\n    .fv-grm-marquee{ overflow:auto; }\n  }\n\n  /* ====== PARCHE EXTRA ====== */\n  .fv-grm-safe, .fv-grm-safe * { min-width: 0; }\n</style>\n\n<div class=\"fv-grm-safe\" id=\"fv-grm-safe\">\n  <div class=\"fv-grm-wrap\" id=\"fv-grm-wrap\">\n    <div class=\"fv-grm-top\">\n      <svg class=\"fv-grm-glogo\" viewBox=\"0 0 48 48\" aria-hidden=\"true\">\n        <path fill=\"#EA4335\" d=\"M24 9.5c3.12 0 5.74 1.08 7.86 2.86l5.36-5.36C33.92 3.82 29.31 2 24 2 14.86 2 6.99 7.24 3.17 14.9l6.63 5.14C11.63 14.03 17.34 9.5 24 9.5z\"/>\n        <path fill=\"#4285F4\" d=\"M46.5 24.5c0-1.57-.14-3.08-.41-4.5H24v9h12.62c-.54 2.89-2.16 5.34-4.6 6.99l7.06 5.47c4.13-3.81 6.42-9.41 6.42-16.96z\"/>\n        <path fill=\"#FBBC05\" d=\"M9.8 28.04A14.4 14.4 0 0 1 9 24c0-1.41.2-2.77.56-4.07L3 14.79A22 22 0 0 0 2 24c0 3.57.85 6.95 2.35 9.94l5.45-5.9z\"/>\n        <path fill=\"#34A853\" d=\"M24 46c5.31 0 9.77-1.75 13.03-4.74l-7.06-5.47c-1.96 1.32-4.47 2.1-7.97 2.1-6.66 0-12.3-4.5-14.32-10.59L4.35 33.94C8.14 41.7 15.03 46 24 46z\"/>\n      </svg>\n\n      <div class=\"fv-grm-title\">Google Reviews</div>\n\n      <div class=\"fv-grm-meta\">\n        <div class=\"fv-grm-rating\">5.0</div>\n        <div class=\"fv-grm-stars\" aria-label=\"5 de 5\">★★★★★</div>\n        <div class=\"fv-grm-count\">(34 opiniones)</div>\n      </div>\n    </div>\n\n    <div class=\"fv-grm-marquee\" id=\"fv-grm-marquee\" aria-label=\"Reseñas de clientes en desplazamiento\">\n      <div class=\"fv-grm-track\" id=\"fv-grm-track\">\n        <div class=\"fv-grm-group\" id=\"fv-grm-groupA\">\n          \n          <article class=\"fv-grm-card\">\n            <div class=\"fv-grm-head\">\n              <img src=\"https://randomuser.me/api/portraits/men/32.jpg\" alt=\"Carlos Mendoza\" class=\"fv-grm-avatar\">\n              <div>\n                <div class=\"fv-grm-name\">Carlos Mendoza</div>\n                <div class=\"fv-grm-stars-small\">★★★★★</div>\n              </div>\n            </div>\n            <p class=\"fv-grm-text\">Increíble tema. Shrine Pro aumentó mis conversiones desde el primer día. Muy fácil de configurar y la velocidad de carga es brutal.</p>\n          </article>\n\n          <article class=\"fv-grm-card\">\n            <div class=\"fv-grm-head\">\n              <img src=\"https://randomuser.me/api/portraits/women/44.jpg\" alt=\"Laura Salazar\" class=\"fv-grm-avatar\">\n              <div>\n                <div class=\"fv-grm-name\">Laura Salazar</div>\n                <div class=\"fv-grm-stars-small\">★★★★★</div>\n              </div>\n            </div>\n            <p class=\"fv-grm-text\">El diseño es súper limpio. Antes usaba un theme gratuito, pero con Shrine Pro mi tienda por fin se ve profesional. ¡100% recomendado!</p>\n          </article>\n\n          <article class=\"fv-grm-card\">\n            <div class=\"fv-grm-head\">\n              <img src=\"https://randomuser.me/api/portraits/men/65.jpg\" alt=\"Diego Torres\" class=\"fv-grm-avatar\">\n              <div>\n                <div class=\"fv-grm-name\">Diego Torres</div>\n                <div class=\"fv-grm-stars-small\">★★★★★</div>\n              </div>\n            </div>\n            <p class=\"fv-grm-text\">Vale cada centavo. La personalización que ofrece este theme no la he visto en ningún otro lado. Además el soporte es muy rápido y resolutivo.</p>\n          </article>\n\n          <article class=\"fv-grm-card\">\n            <div class=\"fv-grm-head\">\n              <img src=\"https://randomuser.me/api/portraits/women/68.jpg\" alt=\"Sofía Castillo\" class=\"fv-grm-avatar\">\n              <div>\n                <div class=\"fv-grm-name\">Sofía Castillo</div>\n                <div class=\"fv-grm-stars-small\">★★★★★</div>\n              </div>\n            </div>\n            <p class=\"fv-grm-text\">Estaba buscando un tema premium para mi tienda de ropa y Shrine Pro superó mis expectativas. Las animaciones y la experiencia en móvil son perfectas. 🚀</p>\n          </article>\n\n          <article class=\"fv-grm-card\">\n            <div class=\"fv-grm-head\">\n              <img src=\"https://randomuser.me/api/portraits/men/85.jpg\" alt=\"Martín Vega\" class=\"fv-grm-avatar\">\n              <div>\n                <div class=\"fv-grm-name\">Martín Vega</div>\n                <div class=\"fv-grm-stars-small\">★★★★★</div>\n              </div>\n            </div>\n            <p class=\"fv-grm-text\">Excelente optimización para SEO. Desde que instalé Shrine Pro en mi tienda de Shopify mis métricas han subido muchísimo. Excelente trabajo del desarrollador.</p>\n          </article>\n\n          <article class=\"fv-grm-card\">\n            <div class=\"fv-grm-head\">\n              <img src=\"https://randomuser.me/api/portraits/women/90.jpg\" alt=\"Andrea Gómez\" class=\"fv-grm-avatar\">\n              <div>\n                <div class=\"fv-grm-name\">Andrea Gómez</div>\n                <div class=\"fv-grm-stars-small\">★★★★★</div>\n              </div>\n            </div>\n            <p class=\"fv-grm-text\">Muy intuitivo. No necesitas saber nada de código para que tu tienda quede espectacular. Es la mejor inversión que he hecho para mi negocio este año.</p>\n          </article>\n\n        </div>\n\n        <div class=\"fv-grm-group\" id=\"fv-grm-groupB\" aria-hidden=\"true\"></div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function(){\n    var marquee = document.getElementById('fv-grm-marquee');\n    var track   = document.getElementById('fv-grm-track');\n    var groupA  = document.getElementById('fv-grm-groupA');\n    var groupB  = document.getElementById('fv-grm-groupB');\n    if (!marquee || !track || !groupA || !groupB) return;\n\n    // Clonar para loop infinito\n    groupB.innerHTML = groupA.innerHTML;\n\n    // Velocidad (20s rápido / 28s normal / 40s lento)\n    track.style.setProperty('--fv-grm-speed', '30s');\n\n    function recalc(){\n      // 1) altura del viewport = altura real del grupo (track es absolute)\n      var h = groupA.getBoundingClientRect().height;\n      marquee.style.height = h + 'px';\n\n      // 2) distancia para el loop = ancho total del grupo A\n      var dist = groupA.getBoundingClientRect().width;\n      track.style.setProperty('--fv-grm-distance', dist + 'px');\n    }\n\n    // Esperar a que el layout del producto termine de acomodarse\n    requestAnimationFrame(function(){\n      recalc();\n      // Por si las fuentes/imagenes cambian altura después\n      setTimeout(recalc, 250);\n      setTimeout(recalc, 900);\n    });\n\n    window.addEventListener('resize', function(){ recalc(); }, { passive:true });\n  })();\n</script>"
          }
        },
