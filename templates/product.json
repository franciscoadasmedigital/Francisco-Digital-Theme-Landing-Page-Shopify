          "settings": {
            "custom_liquid": "{% comment %}\nFV - Google Rating Inline (1 línea en desktop y móvil)\n{% endcomment %}\n\n<style>\n  .fv-rating-inline{\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    font-family: inherit;\n    line-height: 1;\n    width: 100%;\n    margin-top: 10px;\n    white-space: nowrap; /* 🔑 evita salto de línea */\n  }\n\n  .fv-rating-stars{\n    display: flex;\n    gap: 2px;\n    font-size: 15px;\n    color: #FBBC05; /* estrellas */\n    line-height: 1;\n    flex-shrink: 0;\n  }\n\n  .fv-rating-text{\n    color: #111;\n    font-weight: 500;\n    font-size: 13px;\n    flex-shrink: 0;\n  }\n\n  .fv-rating-badge{\n    background: black;\n    color: white;\n    font-weight: 600;\n    font-size: 11px; /* 🔽 más chico para móvil */\n    padding: 4px 7px;\n    border-radius: 6px;\n    flex-shrink: 0;\n  }\n\n  /* Ajuste específico móvil */\n  @media (max-width: 480px){\n    .fv-rating-stars{\n      font-size: 14px;\n    }\n    .fv-rating-text{\n      font-size: 12px;\n    }\n    .fv-rating-badge{\n      font-size: 10.5px;\n      padding: 3px 6px;\n    }\n  }\n</style>\n\n<div class=\"fv-rating-inline\" aria-label=\"Valoración de clientes\">\n  <div class=\"fv-rating-stars\" aria-hidden=\"true\">\n    ★ ★ ★ ★ ☆\n  </div>\n\n  <div class=\"fv-rating-text\">\n    Excelente 4.94/5.0\n  </div>\n\n  <div class=\"fv-rating-badge\">\n    +3.000 Clientes Felices\n  </div>\n</div>"
