    "custom_liquid_BYhbGN": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .fd-services {\n    --accent: #7EAC14;\n    --bg1: #050814;\n    --bg2: #0A1230;\n    --card: rgba(255,255,255,.06);\n    --border: rgba(255,255,255,.10);\n    --text: rgba(255,255,255,.92);\n    --muted: rgba(255,255,255,.70);\n\n    position: relative;\n    overflow: hidden;\n    border-radius: 18px;\n    padding: clamp(18px, 3.2vw, 34px);\n    background: radial-gradient(1000px 500px at 15% 15%, rgba(126,172,20,.22), transparent 55%),\n                radial-gradient(900px 450px at 85% 20%, rgba(126,172,20,.12), transparent 60%),\n                linear-gradient(160deg, var(--bg1), var(--bg2));\n  }\n\n  /* Detalles “diferentes”: halo + diagonales */\n  .fd-services:before,\n  .fd-services:after {\n    content: \"\";\n    position: absolute;\n    inset: -20%;\n    pointer-events: none;\n    opacity: .55;\n  }\n  .fd-services:before{\n    background:\n      linear-gradient(120deg, transparent 35%, rgba(126,172,20,.10) 35%, rgba(126,172,20,.10) 45%, transparent 45%),\n      linear-gradient(120deg, transparent 55%, rgba(255,255,255,.06) 55%, rgba(255,255,255,.06) 62%, transparent 62%);\n    transform: rotate(-6deg);\n  }\n  .fd-services:after{\n    background: radial-gradient(circle at 70% 75%, rgba(126,172,20,.18), transparent 45%);\n    transform: rotate(0deg);\n  }\n\n  .fd-services__head {\n    position: relative;\n    z-index: 1;\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    gap: 16px;\n    margin-bottom: 18px;\n  }\n\n  .fd-services__title {\n    margin: 0;\n    color: var(--text);\n    font-size: clamp(18px, 2vw, 24px);\n    line-height: 1.15;\n    letter-spacing: -0.02em;\n  }\n  .fd-services__subtitle {\n    margin: 6px 0 0;\n    color: var(--muted);\n    font-size: 14px;\n    max-width: 60ch;\n  }\n\n  .fd-services__badge {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    padding: 10px 12px;\n    border-radius: 999px;\n    border: 1px solid rgba(126,172,20,.35);\n    background: rgba(126,172,20,.12);\n    color: var(--text);\n    font-size: 13px;\n    white-space: nowrap;\n  }\n  .fd-services__dot {\n    width: 10px; height: 10px;\n    border-radius: 99px;\n    background: var(--accent);\n    box-shadow: 0 0 0 4px rgba(126,172,20,.18);\n  }\n\n  .fd-services__grid {\n    position: relative;\n    z-index: 1;\n    display: grid;\n    grid-template-columns: repeat(3, minmax(0, 1fr));\n    gap: 18px;\n    margin: 0;\n    padding: 0;\n    list-style: none;\n  }\n\n  .fd-card {\n    border-radius: 18px;\n    background: var(--card);\n    border: 1px solid var(--border);\n    padding: 16px;\n    backdrop-filter: blur(6px);\n    transition: transform .18s ease, border-color .18s ease, background .18s ease;\n    height: 100%;\n  }\n  .fd-card:hover {\n    transform: translateY(-3px);\n    border-color: rgba(126,172,20,.45);\n    background: rgba(255,255,255,.075);\n  }\n\n  .fd-card__media {\n    border-radius: 14px;\n    overflow: hidden;\n    border: 1px solid rgba(126,172,20,.35);\n    background: rgba(0,0,0,.25);\n    aspect-ratio: 16 / 10;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .fd-card__media img{\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    transform: scale(1.02);\n  }\n\n  .fd-card__kicker {\n    display: inline-flex;\n    align-items: center;\n    gap: 8px;\n    margin-top: 14px;\n    color: rgba(255,255,255,.78);\n    font-size: 12px;\n    letter-spacing: .06em;\n    text-transform: uppercase;\n  }\n  .fd-card__kicker:before{\n    content:\"\";\n    width: 18px;\n    height: 2px;\n    border-radius: 99px;\n    background: var(--accent);\n  }\n\n  .fd-card__title{\n    margin: 8px 0 8px;\n    color: var(--text);\n    font-size: 18px;\n    line-height: 1.2;\n    letter-spacing: -0.01em;\n  }\n  .fd-card__text{\n    margin: 0;\n    color: var(--muted);\n    font-size: 14px;\n    line-height: 1.55;\n  }\n\n  .fd-services__cta {\n    position: relative;\n    z-index: 1;\n    margin-top: 18px;\n    display: flex;\n    gap: 12px;\n    align-items: center;\n    flex-wrap: wrap;\n  }\n  .fd-btn {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    padding: 12px 14px;\n    border-radius: 12px;\n    text-decoration: none;\n    font-weight: 600;\n    font-size: 14px;\n    border: 1px solid rgba(126,172,20,.55);\n    background: rgba(126,172,20,.16);\n    color: var(--text);\n    transition: transform .18s ease, background .18s ease;\n  }\n  .fd-btn:hover { transform: translateY(-1px); background: rgba(126,172,20,.22); }\n  .fd-btn svg { width: 16px; height: 16px; }\n\n  .fd-btn--ghost{\n    border-color: rgba(255,255,255,.16);\n    background: rgba(255,255,255,.06);\n  }\n  .fd-btn--ghost:hover{\n    background: rgba(255,255,255,.09);\n  }\n\n  /* Responsive */\n  @media (max-width: 990px){\n    .fd-services__grid { grid-template-columns: 1fr; }\n    .fd-services__head { align-items: flex-start; flex-direction: column; }\n    .fd-services__badge { align-self: flex-start; }\n  }\n</style>\n\n<section class=\"fd-services\" role=\"region\" aria-label=\"Servicios\">\n  <div class=\"fd-services__head\">\n    <div>\n      <h2 class=\"fd-services__title\">Servicios digitales</h2>\n      <p class=\"fd-services__subtitle\">\n        Tres soluciones enfocadas en resultados: presencia online, ventas y desarrollos a medida.\n      </p>\n    </div>\n\n    <div class=\"fd-services__badge\">\n      <span class=\"fd-services__dot\" aria-hidden=\"true\"></span>\n      <span>Color acento: #7EAC14</span>\n    </div>\n  </div>\n\n  <ul class=\"fd-services__grid\">\n    <li class=\"fd-card\">\n      <div class=\"fd-card__media\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0623/0851/5895/files/Ejemplo_de_Servicios_3.jpg?v=1770604208\"\n          alt=\"Sitios web corporativos\"\n          loading=\"lazy\">\n      </div>\n      <div class=\"fd-card__kicker\">Presencia</div>\n      <h3 class=\"fd-card__title\">Sitios web corporativos</h3>\n      <p class=\"fd-card__text\">\n        Webs modernas para presentar tu negocio con claridad, generar confianza y convertir visitas en contactos.\n      </p>\n    </li>\n\n    <li class=\"fd-card\">\n      <div class=\"fd-card__media\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0623/0851/5895/files/original-b113971a091ebeb9d7c02927c7f61dec.webp?v=1770604189\"\n          alt=\"Sitios web e-commerce\"\n          loading=\"lazy\">\n      </div>\n      <div class=\"fd-card__kicker\">Ventas</div>\n      <h3 class=\"fd-card__title\">Sitios web e-commerce</h3>\n      <p class=\"fd-card__text\">\n        Tiendas optimizadas para vender: experiencia rápida, checkout claro, y estructura lista para escalar con ads y SEO.\n      </p>\n    </li>\n\n    <li class=\"fd-card\">\n      <div class=\"fd-card__media\">\n        <img\n          src=\"https://cdn.shopify.com/s/files/1/0623/0851/5895/files/original-52a6923baf7104b1630424babb6b8fca.webp?v=1770604189\"\n          alt=\"Proyectos a medida\"\n          loading=\"lazy\">\n      </div>\n      <div class=\"fd-card__kicker\">Automatización</div>\n      <h3 class=\"fd-card__title\">Proyectos a medida</h3>\n      <p class=\"fd-card__text\">\n        Desde integraciones y automatizaciones con IA hasta secciones personalizadas y funcionalidades específicas.\n      </p>\n    </li>\n  </ul>\n\n  <div class=\"fd-services__cta\">\n    <a class=\"fd-btn\" href=\"/pages/contact\">\n      Cotizar ahora\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n        <path d=\"M5 12h12\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        <path d=\"M13 6l6 6-6 6\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n      </svg>\n    </a>\n\n    <a class=\"fd-btn fd-btn--ghost\" href=\"/pages/servicios\">\n      Ver detalles\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" aria-hidden=\"true\">\n        <path d=\"M12 5v14\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n        <path d=\"M5 12h14\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"/>\n      </svg>\n    </a>\n  </div>\n</section>",
