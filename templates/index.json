      "settings": {
        "custom_liquid": "<div class=\"fd-services-title\" data-fd-animate-words>\n  <h2 class=\"fd-services-title__h\">\n    <span class=\"fd-word\">Nuestros</span>\n    <span class=\"fd-word fd-accent\">Servicios</span>\n  </h2>\n\n  <div class=\"fd-services-title__divider\" aria-hidden=\"true\"></div>\n\n  <p class=\"fd-services-title__sub\">\n    <span class=\"fd-word\">Tres</span>\n    <span class=\"fd-word\">servicios</span>\n    <span class=\"fd-word\">diseñados</span>\n    <span class=\"fd-word\">para</span>\n    <span class=\"fd-word\">hacer</span>\n    <span class=\"fd-word\">crecer</span>\n    <span class=\"fd-word\">tu</span>\n    <span class=\"fd-word\">negocio</span>\n  </p>\n</div>\n\n<style>\n  .fd-services-title{\n    width: 100%;\n    max-width: 1100px;\n    margin: 0 auto;\n    padding: clamp(18px, 3vw, 36px) 16px;\n    text-align: center;\n  }\n\n  .fd-services-title__h{\n    margin: 0;\n    line-height: 1.05;\n    font-weight: 900;\n    letter-spacing: -0.02em;\n    font-size: clamp(34px, 6vw, 72px);\n  }\n\n  .fd-accent{\n    color: #7fb10a; /* verde similar al de la imagen */\n  }\n\n  .fd-services-title__divider{\n    height: 2px;\n    width: min(520px, 92%);\n    margin: 14px auto 10px;\n    background: #111;\n    opacity: .9;\n  }\n\n  .fd-services-title__sub{\n    margin: 0;\n    font-size: clamp(14px, 2.2vw, 24px);\n    line-height: 1.35;\n    color: #111;\n    font-weight: 500;\n  }\n\n  /* Animación por palabra */\n  .fd-word{\n    display: inline-block;\n    will-change: transform, opacity;\n    transform: translateY(14px);\n    opacity: 0;\n    transition: transform 700ms cubic-bezier(.2,.8,.2,1), opacity 700ms ease;\n  }\n\n  /* Estado visible */\n  .fd-services-title.is-visible .fd-word{\n    transform: translateY(0);\n    opacity: 1;\n  }\n\n  /* Accesibilidad: respeta reduce motion */\n  @media (prefers-reduced-motion: reduce){\n    .fd-word{\n      transition: none !important;\n      transform: none !important;\n      opacity: 1 !important;\n    }\n  }\n</style>\n\n<script>\n  (function(){\n    const root = document.querySelector('[data-fd-animate-words]');\n    if(!root) return;\n\n    const words = root.querySelectorAll('.fd-word');\n    // Stagger\n    words.forEach((w, i) => {\n      w.style.transitionDelay = (i * 70) + 'ms';\n    });\n\n    // Mostrar al entrar en viewport\n    const reveal = () => root.classList.add('is-visible');\n\n    if ('IntersectionObserver' in window) {\n      const io = new IntersectionObserver((entries) => {\n        entries.forEach(entry => {\n          if(entry.isIntersecting){\n            reveal();\n            io.disconnect();\n          }\n        });\n      }, { threshold: 0.25 });\n      io.observe(root);\n    } else {\n      // fallback\n      reveal();\n    }\n  })();\n</script>",
