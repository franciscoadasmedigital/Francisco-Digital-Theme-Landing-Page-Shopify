        "custom_liquid": "<div class=\"fd-services-title\">\n  <h2 class=\"fd-services-title__h\">\n    <span>Nosotros</span>\n    <span class=\"fd-underline\">\n      Servicios\n    </span>\n  </h2>\n\n  <div class=\"fd-services-title__divider\"></div>\n\n  <p class=\"fd-services-title__sub\">\n    Tres servicios diseñados para hacer crecer tu negocio\n  </p>\n</div>\n\n<style>\n.fd-services-title{\n  width:100%;\n  max-width:1100px;\n  margin:0 auto;\n  padding:clamp(20px,3vw,40px) 16px;\n  text-align:center;\n}\n\n.fd-services-title__h{\n  margin:0;\n  font-weight:900;\n  font-size:clamp(36px,6vw,72px);\n  letter-spacing:-0.02em;\n  line-height:1.05;\n}\n\n.fd-services-title__h span:first-child{\n  margin-right:12px;\n}\n\n.fd-underline{\n  position:relative;\n  color:#7fb10a; /* Verde */\n  display:inline-block;\n}\n\n/* Línea subrayado animada */\n.fd-underline::after{\n  content:\"\";\n  position:absolute;\n  left:0;\n  bottom:-8px;\n  width:100%;\n  height:6px;\n  background:#7fb10a;\n  transform:scaleX(0);\n  transform-origin:left;\n  transition:transform 0.8s cubic-bezier(.77,0,.18,1);\n  border-radius:3px;\n}\n\n/* Activación al aparecer */\n.fd-services-title.is-visible .fd-underline::after{\n  transform:scaleX(1);\n}\n\n.fd-services-title__divider{\n  height:2px;\n  width:min(520px,92%);\n  margin:16px auto 10px;\n  background:#111;\n}\n\n.fd-services-title__sub{\n  margin:13px;\n  font-size:clamp(14px,2.2vw,24px);\n  line-height:1.35;\n  color:#111;\n  font-weight:500;\n}\n\n/* Accesibilidad */\n@media (prefers-reduced-motion: reduce){\n  .fd-underline::after{\n    transition:none;\n    transform:scaleX(1);\n  }\n}\n</style>\n\n<script>\n(function(){\n  const section = document.querySelector('.fd-services-title');\n  if(!section) return;\n\n  if ('IntersectionObserver' in window) {\n    const observer = new IntersectionObserver((entries)=>{\n      entries.forEach(entry=>{\n        if(entry.isIntersecting){\n          section.classList.add('is-visible');\n          observer.disconnect();\n        }\n      });\n    },{threshold:0.3});\n    observer.observe(section);\n  } else {\n    section.classList.add('is-visible');\n  }\n})();\n</script>",
